NODE_ENV=production
APP_ENV=production
HOST=127.0.0.1
PORT=8797
DATABASE_FILE=/opt/huicien-v2/backend/data/huicien.sqlite
LOG_DIR=/var/log/huicien-v2/backend
UPLOAD_DIR=/opt/huicien-v2/backend/uploads
TOKEN_TTL_SECONDS=3600
MAX_BODY_BYTES=1048576
CORS_ALLOWED_ORIGINS=https://org.huicien.com,https://admin.huicien.com
TRUST_PROXY=true
SEED_TEST_DATA=false
ALLOW_DEMO_AUTH=false

WECHAT_LOGIN_ENABLED=false
WECHAT_PAYMENT_ENABLED=false
MINIPROGRAM_ENABLED=false
SUBSCRIBE_MESSAGE_ENABLED=false

BOOTSTRAP_INSTITUTION_PASSWORD=REPLACE_WITH_SECRET_MANAGER_VALUE
BOOTSTRAP_ADMIN_LOGIN_NAME=huicien_admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=平台总管理员
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_SECRET_MANAGER_VALUE
DATA_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_SECRET_MANAGER_VALUE
ORG_API_BASE_URL=https://api.huicien.com
ADMIN_API_BASE_URL=https://api.huicien.com
