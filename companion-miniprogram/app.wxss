page {
  --color-primary: #1261d3;
  --color-primary-soft: #eaf2ff;
  --color-page: #f4f7fb;
  --color-card: #ffffff;
  --color-text-primary: #172033;
  --color-text-secondary: #697386;
  --color-text-tertiary: #98a1b2;
  --color-divider: #e8edf4;
  --color-success: #21a366;
  --color-success-soft: #e9f8f0;
  --color-warning: #e98518;
  --color-warning-soft: #fff4e8;
  --color-error: #d83b3b;
  --color-error-soft: #fff0f0;
  --page-gutter: 32rpx;
  --radius-card: 28rpx;
  --radius-button: 24rpx;
  --shadow-card: 0 12rpx 36rpx rgba(26, 72, 126, 0.08);
  min-height: 100%;
  box-sizing: border-box;
  background: var(--color-page);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
image,
scroll-view,
switch,
checkbox {
  box-sizing: border-box;
}

button {
  min-width: 0;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  background: transparent;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx var(--page-gutter) calc(40rpx + env(safe-area-inset-bottom));
}

.card {
  border: 1rpx solid rgba(18, 97, 211, 0.05);
  border-radius: var(--radius-card);
  background: var(--color-card);
  box-shadow: var(--shadow-card);
}

.primary-button {
  width: 100%;
  height: 92rpx;
  border-radius: var(--radius-button);
  color: #ffffff;
  background: var(--color-primary);
  font-size: 29rpx;
  font-weight: 700;
}

.primary-button[disabled] {
  opacity: 0.48;
}

.tap-feedback {
  transition: opacity 160ms ease, transform 160ms ease;
}

.tap-feedback:active {
  opacity: 0.76;
  transform: scale(0.985);
}

.page-with-footer {
  padding-bottom: calc(152rpx + env(safe-area-inset-bottom));
}

.fixed-action-bar {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 128rpx;
  padding: 18rpx var(--page-gutter) calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-top: 1rpx solid var(--color-divider);
  background: rgba(255, 255, 255, 0.97);
}

.secondary-button {
  min-width: 176rpx;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-button);
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 27rpx;
  font-weight: 700;
}

.companion-status-chip {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 700;
}

.companion-status-chip.orange {
  color: var(--color-warning);
  background: var(--color-warning-soft);
}

.companion-status-chip.blue {
  color: var(--color-primary);
  background: var(--color-primary-soft);
}

.companion-status-chip.green {
  color: var(--color-success);
  background: var(--color-success-soft);
}

.companion-status-chip.gray {
  color: var(--color-text-secondary);
  background: var(--color-divider);
}

.form-card {
  padding: 28rpx;
}

.form-section-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 29rpx;
  font-weight: 750;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--color-text-secondary);
  font-size: 23rpx;
  font-weight: 600;
}

.text-area {
  width: 100%;
  min-height: 184rpx;
  padding: 22rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 20rpx;
  background: var(--color-page);
  font-size: 26rpx;
  line-height: 40rpx;
}
