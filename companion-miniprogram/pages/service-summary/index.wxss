.summary-page {
  padding-top: 20rpx;
  padding-bottom: calc(188rpx + env(safe-area-inset-bottom));
}

.loading-state {
  padding: 180rpx 0;
  color: var(--color-text-secondary);
  text-align: center;
}

.summary-head,
.record-summary,
.exception-card {
  padding: 28rpx;
}

.expense-summary {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.expense-summary text {
  display: block;
}

.expense-summary text:first-child {
  font-size: 25rpx;
  font-weight: 700;
}

.expense-summary text:last-child {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.expense-summary button {
  width: auto;
  height: 68rpx;
  padding-left: 20rpx;
  flex: none;
  color: var(--color-primary);
  font-size: 21rpx;
  font-weight: 700;
}

.head-label,
.head-title,
.head-location {
  display: block;
}

.head-label {
  color: var(--color-success);
  font-size: 22rpx;
  font-weight: 700;
}

.head-title {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 750;
}

.head-location {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.time-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.time-grid view {
  padding: 18rpx;
  border-radius: 18rpx;
  background: var(--color-page);
}

.time-grid text {
  display: block;
}

.time-grid text:first-child {
  color: var(--color-text-secondary);
  font-size: 19rpx;
}

.time-grid text:last-child {
  margin-top: 6rpx;
  font-size: 21rpx;
  font-weight: 650;
}

.record-summary,
.form-card,
.exception-card {
  margin-top: 20rpx;
}

.summary-form {
  overflow: hidden;
}

.summary-form .text-area {
  display: block;
  width: 100%;
  max-width: 100%;
  margin-left: 0;
  margin-right: 0;
  box-sizing: border-box;
}

.summary-form .text-area:not(.short) {
  height: 264rpx;
  min-height: 264rpx;
}

.record-numbers {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.record-numbers view {
  text-align: center;
  border-right: 1rpx solid var(--color-divider);
}

.record-numbers view:last-child {
  border-right: 0;
}

.record-numbers text {
  display: block;
}

.record-numbers text:first-child {
  color: var(--color-primary);
  font-size: 34rpx;
  font-weight: 750;
}

.record-numbers text:last-child {
  margin-top: 5rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.field-hint {
  display: block;
  margin-top: 9rpx;
  color: var(--color-text-tertiary);
  font-size: 19rpx;
  text-align: right;
}

.field-gap {
  margin-top: 26rpx;
}

.text-area.short {
  height: 172rpx;
  min-height: 172rpx;
}

.exception-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.exception-card text {
  display: block;
}

.exception-card text:first-child {
  font-size: 25rpx;
  font-weight: 700;
}

.exception-card text:last-child {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.submit-notice {
  margin: 24rpx 6rpx 0;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: var(--color-text-tertiary);
  font-size: 20rpx;
  line-height: 32rpx;
}

.submit-notice view {
  width: 12rpx;
  height: 12rpx;
  margin-top: 9rpx;
  flex: none;
  border-radius: 50%;
  background: var(--color-primary);
}
