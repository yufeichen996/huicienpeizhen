.execution-page {
  padding-top: 20rpx;
}

.loading-state {
  padding: 180rpx 0;
  color: var(--color-text-secondary);
  text-align: center;
}

.service-head {
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.head-label,
.head-name,
.head-location,
.service-timer text {
  display: block;
}

.head-label {
  color: var(--color-success);
  font-size: 22rpx;
  font-weight: 700;
}

.head-name {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 750;
}

.head-location {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 21rpx;
}

.service-timer {
  min-width: 132rpx;
  padding: 18rpx 14rpx;
  flex: none;
  border-radius: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  text-align: center;
}

.service-timer text:first-child {
  font-size: 31rpx;
  font-weight: 750;
  font-variant-numeric: tabular-nums;
}

.service-timer text:last-child {
  margin-top: 4rpx;
  font-size: 19rpx;
}

.progress-card {
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
}

.progress-copy {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
}

.progress-copy text:first-child {
  font-weight: 700;
}

.progress-copy text:last-child {
  color: var(--color-text-secondary);
}

.progress-track {
  height: 12rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: var(--color-divider);
}

.progress-track view {
  height: 100%;
  border-radius: inherit;
  background: var(--color-success);
  transition: width 200ms ease;
}

.milestone-list {
  margin-top: 20rpx;
}

.milestone-row {
  position: relative;
  padding-left: 54rpx;
}

.milestone-row + .milestone-row {
  margin-top: 16rpx;
}

.milestone-state {
  position: absolute;
  z-index: 2;
  top: 30rpx;
  bottom: -30rpx;
  left: 0;
  width: 40rpx;
  display: flex;
  justify-content: center;
}

.state-mark {
  z-index: 1;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid var(--color-divider);
  border-radius: 50%;
  color: #ffffff;
  background: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.active-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ffffff;
}

.state-line {
  position: absolute;
  top: 40rpx;
  bottom: -16rpx;
  width: 3rpx;
  background: var(--color-divider);
}

.status-completed .state-mark {
  border-color: var(--color-success);
  background: var(--color-success);
}

.status-active .state-mark {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.status-failed .state-mark {
  border-color: var(--color-warning);
  background: var(--color-warning);
}

.status-completed .state-line {
  background: rgba(30, 167, 101, 0.42);
}

.status-failed .state-line {
  background: rgba(234, 145, 24, 0.42);
}

.milestone-card {
  min-height: 148rpx;
  padding: 24rpx 26rpx;
  border: 1rpx solid rgba(153, 167, 186, 0.18);
  box-shadow: 0 8rpx 24rpx rgba(35, 64, 104, 0.06);
}

.status-active .milestone-card {
  border: 2rpx solid rgba(18, 97, 211, 0.62);
  box-shadow: 0 8rpx 24rpx rgba(18, 97, 211, 0.08);
}

.status-completed .milestone-card {
  opacity: 0.74;
  box-shadow: none;
}

.status-failed .milestone-card {
  border-color: rgba(234, 145, 24, 0.4);
}

.milestone-header,
.failure-heading,
.evidence-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.node-index {
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 750;
}

.status-label {
  padding: 6rpx 13rpx;
  border-radius: 999rpx;
  color: var(--color-text-tertiary);
  background: var(--color-page);
  font-size: 19rpx;
  font-weight: 650;
}

.status-active .status-label {
  color: var(--color-primary);
  background: var(--color-primary-soft);
}

.status-completed .status-label {
  color: var(--color-success);
  background: var(--color-success-soft);
}

.status-failed .status-label {
  color: var(--color-warning);
  background: var(--color-warning-soft);
}

.milestone-title,
.milestone-desc {
  display: block;
}

.milestone-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 750;
}

.milestone-desc {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 21rpx;
  line-height: 34rpx;
}

.node-tags {
  margin-top: 11rpx;
}

.required-label,
.optional-label {
  display: inline-block;
  padding: 5rpx 11rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
}

.required-label {
  color: var(--color-warning);
  background: var(--color-warning-soft);
}

.optional-label {
  color: var(--color-text-secondary);
  background: var(--color-page);
}

.node-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 14rpx;
}

.fail-button,
.complete-button {
  height: 80rpx;
  flex: 1;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.fail-button {
  color: var(--color-warning);
  background: var(--color-warning-soft);
}

.complete-button {
  color: #ffffff;
  background: var(--color-success);
}

.failure-panel {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 18rpx;
  background: #f8fafc;
}

.failure-heading > text {
  font-size: 24rpx;
  font-weight: 750;
}

.collapse-button {
  width: auto;
  height: 56rpx;
  padding: 0 8rpx;
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 650;
}

.failure-textarea {
  display: block;
  width: 100%;
  height: 176rpx;
  min-height: 176rpx;
  margin-top: 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--color-divider);
  border-radius: 16rpx;
  background: #ffffff;
  font-size: 23rpx;
  line-height: 36rpx;
}

.character-count {
  display: block;
  margin-top: 7rpx;
  color: var(--color-text-tertiary);
  font-size: 18rpx;
  text-align: right;
}

.evidence-heading {
  margin-top: 16rpx;
}

.evidence-heading text {
  display: block;
}

.evidence-heading text:first-child {
  font-size: 22rpx;
  font-weight: 700;
}

.evidence-heading text:last-child {
  margin-top: 3rpx;
  color: var(--color-text-tertiary);
  font-size: 18rpx;
}

.evidence-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.evidence-item,
.add-evidence {
  position: relative;
  height: 132rpx;
  overflow: hidden;
  border-radius: 14rpx;
}

.evidence-item image {
  width: 100%;
  height: 100%;
}

.remove-evidence {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 38rpx;
  min-width: 38rpx;
  height: 38rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: rgba(24, 32, 44, 0.72);
  font-size: 28rpx;
  line-height: 38rpx;
}

.add-evidence {
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed rgba(18, 97, 211, 0.38);
  color: var(--color-primary);
  background: var(--color-primary-soft);
}

.add-evidence text {
  display: block;
  font-size: 19rpx;
}

.add-evidence text:first-child {
  font-size: 36rpx;
  line-height: 36rpx;
}

.submit-failure {
  width: 100%;
  height: 76rpx;
  margin-top: 18rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: var(--color-warning);
  font-size: 23rpx;
  font-weight: 700;
}

.node-result {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  color: var(--color-text-secondary);
  background: var(--color-page);
  font-size: 20rpx;
  line-height: 32rpx;
}

.node-result > text {
  display: block;
}

.failed-result {
  color: #9a5a0a;
  background: var(--color-warning-soft);
}

.result-title {
  margin-bottom: 4rpx;
  color: var(--color-warning);
  font-weight: 700;
}

.result-time {
  margin-top: 6rpx;
  color: var(--color-text-tertiary);
}

.result-evidence {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.result-evidence image {
  width: 100%;
  height: 104rpx;
  border-radius: 12rpx;
}

.expense-entry {
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.expense-entry > view {
  min-width: 0;
  flex: 1;
}

.expense-entry text {
  display: block;
}

.expense-entry text:first-child {
  font-size: 24rpx;
  font-weight: 700;
}

.expense-entry text:last-child {
  margin-top: 6rpx;
  color: var(--color-text-secondary);
  font-size: 19rpx;
}

.expense-entry button {
  width: auto;
  height: 68rpx;
  padding-left: 20rpx;
  flex: none;
  color: var(--color-primary);
  font-size: 21rpx;
  font-weight: 700;
}

.weak-network-tip {
  margin: 24rpx 6rpx 0;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: var(--color-text-tertiary);
  font-size: 20rpx;
  line-height: 32rpx;
}

.weak-network-tip view {
  width: 12rpx;
  height: 12rpx;
  margin-top: 9rpx;
  flex: none;
  border-radius: 50%;
  background: var(--color-warning);
}
