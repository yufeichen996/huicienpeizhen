.notification-page {
  padding-top: 24rpx;
}

.hero-card {
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #1261d3 0%, #4c92ed 100%);
  box-shadow: 0 16rpx 38rpx rgba(18, 97, 211, 0.2);
}

.bell-mark {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  flex: none;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
}

.bell-body {
  position: absolute;
  top: 21rpx;
  left: 26rpx;
  width: 36rpx;
  height: 38rpx;
  border: 6rpx solid var(--color-primary);
  border-radius: 22rpx 22rpx 10rpx 10rpx;
}

.bell-dot {
  position: absolute;
  bottom: 18rpx;
  left: 38rpx;
  width: 12rpx;
  height: 7rpx;
  border-radius: 0 0 10rpx 10rpx;
  background: var(--color-primary);
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.hero-copy text {
  display: block;
  color: #ffffff;
}

.hero-copy text:first-child {
  font-size: 31rpx;
  font-weight: 750;
}

.hero-copy text:last-child {
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 34rpx;
  opacity: 0.88;
}

.subscription-card {
  margin-top: 24rpx;
  padding: 0 28rpx;
}

.subscription-row {
  min-height: 136rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.subscription-row:last-child {
  border-bottom: 0;
}

.row-copy {
  min-width: 0;
  flex: 1;
}

.row-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.row-title > text:first-child {
  font-size: 26rpx;
  font-weight: 700;
}

.status {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  color: var(--color-text-secondary);
  background: var(--color-page);
  font-size: 18rpx;
}

.status.accepted {
  color: var(--color-success);
  background: var(--color-success-soft);
}

.status.banned {
  color: var(--color-error);
  background: var(--color-error-soft);
}

.row-copy > text {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
  line-height: 32rpx;
}

.row-action {
  width: 128rpx;
  height: 68rpx;
  flex: none;
  border-radius: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 22rpx;
  font-weight: 700;
}

.row-action[disabled] {
  color: var(--color-text-tertiary);
  background: var(--color-page);
}

.primary-button {
  margin-top: 24rpx;
}

.setting-button {
  width: 100%;
  height: 88rpx;
  margin-top: 16rpx;
  border-radius: 22rpx;
  color: var(--color-primary);
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}

.notice {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-primary-soft);
}

.notice text {
  display: block;
  font-size: 20rpx;
  line-height: 34rpx;
}

.notice text:first-child {
  margin-bottom: 8rpx;
  color: var(--color-primary);
  font-weight: 700;
}

.notice text + text + text {
  margin-top: 8rpx;
}
