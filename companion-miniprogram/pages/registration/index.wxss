.registration-page {
  padding-top: 20rpx;
}

.registration-head {
  padding: 30rpx;
}

.registration-head text {
  display: block;
}

.registration-head text:first-child {
  font-size: 34rpx;
  font-weight: 750;
}

.registration-head text:last-child {
  margin-top: 10rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  line-height: 36rpx;
}

.form-card {
  margin-top: 20rpx;
}

.field-input,
.years-input {
  width: 100%;
  height: 88rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 20rpx;
  background: var(--color-page);
  font-size: 25rpx;
}

.field-input {
  display: flex;
  align-items: center;
}

.field-gap {
  margin-top: 24rpx;
}

.gender-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.gender-row view,
.selection-grid view {
  min-height: 72rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  border-radius: 18rpx;
  color: var(--color-text-secondary);
  background: var(--color-page);
  font-size: 22rpx;
  text-align: center;
}

.gender-row view.active,
.selection-grid view.active {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-weight: 700;
}

.years-input {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.years-input input {
  height: 100%;
  flex: 1;
}

.years-input text {
  color: var(--color-text-secondary);
}

.selection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.selection-grid.districts {
  grid-template-columns: repeat(3, 1fr);
}

.text-area {
  min-height: 170rpx;
}

.upload-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.upload-item,
.add-upload {
  position: relative;
  height: 150rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.remove-upload {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  min-width: 48rpx;
  max-width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #ffffff;
  background: rgba(23, 32, 51, 0.72);
  font-size: 30rpx;
}

.add-upload {
  display: flex;
  flex-direction: column;
  border: 2rpx dashed #cbd5e3;
  color: var(--color-text-secondary);
  background: var(--color-page);
}

.add-upload text {
  display: block;
}

.add-upload text:first-child {
  color: var(--color-primary);
  font-size: 38rpx;
}

.add-upload text:last-child {
  margin-top: 4rpx;
  font-size: 19rpx;
}

.privacy-notice {
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 22rpx;
  background: var(--color-warning-soft);
}

.privacy-notice text {
  display: block;
}

.privacy-notice text:first-child {
  color: var(--color-warning);
  font-size: 21rpx;
  font-weight: 700;
}

.privacy-notice text:last-child {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
  line-height: 34rpx;
}

.agreement {
  min-height: 84rpx;
  margin-top: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: var(--color-text-secondary);
  font-size: 21rpx;
  line-height: 34rpx;
}

.agreement checkbox {
  transform: scale(0.82);
  transform-origin: left top;
}
