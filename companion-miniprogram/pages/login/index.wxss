.login-page {
  min-height: 100vh;
  padding: 76rpx var(--page-gutter) calc(36rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-mark {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  background: var(--color-primary);
  box-shadow: 0 18rpx 40rpx rgba(18, 97, 211, 0.22);
}

.cross {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 8rpx;
  background: #ffffff;
  transform: translate(-50%, -50%);
}

.cross-horizontal {
  width: 58rpx;
  height: 16rpx;
}

.cross-vertical {
  width: 16rpx;
  height: 58rpx;
}

.brand-name {
  margin-top: 28rpx;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 750;
}

.brand-desc {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.login-card {
  margin-top: 64rpx;
  padding: 30rpx;
}

.card-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 31rpx;
  font-weight: 700;
}

.benefit-row {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.benefit-row:last-child {
  border-bottom: 0;
}

.benefit-index {
  width: 52rpx;
  color: var(--color-primary);
  font-size: 23rpx;
  font-weight: 750;
}

.benefit-title,
.benefit-desc {
  display: block;
}

.benefit-title {
  font-weight: 650;
}

.benefit-desc {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.login-footer {
  margin-top: auto;
  padding-top: 48rpx;
}

.agreement-group {
  width: 100%;
  display: flex;
  justify-content: center;
}

.agreement {
  min-height: 56rpx;
  margin-top: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  line-height: 34rpx;
  text-align: left;
}

.agreement checkbox {
  flex: none;
  transform: scale(0.82);
  transform-origin: center;
}

.environment-note {
  display: block;
  margin-top: 18rpx;
  color: var(--color-text-tertiary);
  font-size: 20rpx;
  text-align: center;
}

.register-button {
  width: 100%;
  height: 88rpx;
  margin-top: 14rpx;
  border-radius: var(--radius-button);
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 27rpx;
  font-weight: 700;
}

.application-button {
  width: 100%;
  height: 76rpx;
  margin-top: 10rpx;
  color: var(--color-warning);
  font-size: 22rpx;
  font-weight: 650;
}
