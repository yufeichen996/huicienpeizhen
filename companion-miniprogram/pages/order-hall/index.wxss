.hall-page {
  padding-top: 20rpx;
}

.hall-hero {
  min-height: 220rpx;
  padding: 34rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  overflow: hidden;
  border-radius: 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f315e 0%, #1261d3 100%);
  box-shadow: 0 18rpx 42rpx rgba(18, 97, 211, 0.18);
}

.hall-copy {
  min-width: 0;
  flex: 1;
  text-align: left;
}

.hall-eyebrow,
.hall-title,
.hall-desc,
.hall-count text {
  display: block;
}

.hall-eyebrow {
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
  font-weight: 750;
  letter-spacing: 3rpx;
}

.hall-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 50rpx;
  font-weight: 750;
}

.hall-desc {
  max-width: 420rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 21rpx;
  line-height: 34rpx;
}

.hall-count {
  width: 130rpx;
  height: 130rpx;
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.hall-count text:first-child {
  font-size: 42rpx;
  font-weight: 750;
  font-variant-numeric: tabular-nums;
}

.hall-count text:last-child {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
}

.policy-strip {
  margin-top: 18rpx;
  padding: 22rpx 12rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.policy-strip view {
  min-width: 0;
  padding: 0 10rpx;
  text-align: center;
  border-right: 1rpx solid var(--color-divider);
}

.policy-strip view:last-child {
  border-right: 0;
}

.policy-strip text {
  display: block;
}

.policy-strip text:first-child {
  color: var(--color-primary);
  font-size: 25rpx;
  font-weight: 750;
}

.policy-strip text:last-child {
  margin-top: 5rpx;
  color: var(--color-text-secondary);
  font-size: 18rpx;
}

.privacy-tip {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  border-radius: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 20rpx;
  line-height: 33rpx;
}

.privacy-tip view {
  width: 15rpx;
  height: 15rpx;
  margin-top: 8rpx;
  flex: none;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.hall-head {
  margin: 32rpx 4rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hall-head text:first-child {
  font-size: 30rpx;
  font-weight: 750;
}

.hall-head text:last-child {
  color: var(--color-text-secondary);
  font-size: 21rpx;
}

.loading-state {
  padding: 150rpx 0;
  color: var(--color-text-secondary);
  text-align: center;
}

.grab-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  text-align: left;
}

.source-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--color-text-secondary);
  font-size: 19rpx;
}

.source-row > text:nth-child(2) {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-row > text:last-child {
  flex: none;
  color: var(--color-text-tertiary);
  font-size: 18rpx;
}

.source-badge {
  padding: 5rpx 10rpx;
  flex: none;
  border-radius: 999rpx;
  color: var(--color-success);
  background: var(--color-success-soft);
  font-size: 18rpx;
  font-weight: 700;
}

.service-row {
  margin-top: 22rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.service-name,
.patient-summary {
  display: block;
}

.service-name {
  font-size: 34rpx;
  font-weight: 750;
}

.patient-summary {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 21rpx;
}

.fee-block {
  flex: none;
  text-align: right;
}

.fee-block text {
  display: block;
}

.fee-block text:first-child {
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: 750;
}

.fee-block text:last-child {
  margin-top: 3rpx;
  color: var(--color-text-tertiary);
  font-size: 18rpx;
}

.key-info {
  margin-top: 22rpx;
  padding: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  border-radius: 20rpx;
  background: var(--color-page);
}

.key-info view {
  min-width: 0;
}

.key-info text {
  display: block;
}

.key-info text:first-child {
  color: var(--color-text-secondary);
  font-size: 18rpx;
}

.key-info text:last-child {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 700;
}

.detail-line {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  color: var(--color-text-secondary);
  font-size: 19rpx;
  line-height: 30rpx;
}

.detail-line text {
  min-width: 0;
  flex: 1;
}

.detail-line text:last-child {
  text-align: right;
}

.need-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.need-list text {
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 19rpx;
}

.claim-button {
  width: 100%;
  height: 84rpx;
  margin-top: 22rpx;
  border-radius: 22rpx;
  color: #ffffff;
  background: var(--color-primary);
  font-size: 26rpx;
  font-weight: 700;
}

.claim-button[disabled] {
  opacity: 0.55;
}

.empty-card {
  padding: 72rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-symbol {
  width: 82rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background: var(--color-primary-soft);
}

.empty-symbol view {
  width: 30rpx;
  height: 30rpx;
  border: 5rpx solid var(--color-primary);
  border-radius: 50%;
}

.empty-title {
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-desc {
  max-width: 480rpx;
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 21rpx;
  line-height: 34rpx;
}

.refresh-button {
  width: 200rpx;
  height: 76rpx;
  margin-top: 24rpx;
  border-radius: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 23rpx;
  font-weight: 700;
}

.hall-rules {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.hall-rules text {
  display: block;
}

.hall-rules text:first-child {
  font-size: 22rpx;
  font-weight: 700;
}

.hall-rules text:last-child {
  margin-top: 7rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
  line-height: 34rpx;
}
