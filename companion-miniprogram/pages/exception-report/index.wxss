.exception-page {
  padding-top: 20rpx;
}

.guidance {
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.guidance-mark {
  width: 56rpx;
  height: 56rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: var(--color-warning);
  background: var(--color-warning-soft);
  font-size: 28rpx;
  font-weight: 750;
}

.guidance text {
  display: block;
}

.guidance text:first-child {
  font-size: 24rpx;
  font-weight: 700;
}

.guidance text:last-child {
  margin-top: 5rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.form-card {
  margin-top: 20rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.category-option {
  min-height: 74rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid transparent;
  border-radius: 18rpx;
  color: var(--color-text-secondary);
  background: var(--color-page);
  font-size: 22rpx;
}

.category-option.active {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-weight: 650;
}

.category-option.high-risk::after {
  content: "重点";
  margin-left: auto;
  color: var(--color-error);
  font-size: 17rpx;
}

.urgency-option {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.urgency-option:last-child {
  border-bottom: 0;
}

.radio-mark {
  width: 34rpx;
  height: 34rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid var(--color-divider);
  border-radius: 50%;
}

.urgency-option.active .radio-mark {
  border-color: var(--color-primary);
}

.radio-mark view {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.urgency-option.active .radio-mark view {
  background: var(--color-primary);
}

.urgency-option text {
  display: block;
}

.urgency-option text:first-child {
  font-size: 24rpx;
  font-weight: 650;
}

.urgency-option text:last-child {
  margin-top: 4rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.emergency-notice {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(216, 59, 59, 0.14);
  border-radius: var(--radius-card);
  background: var(--color-error-soft);
}

.emergency-notice > text {
  display: block;
}

.emergency-notice > text:first-child {
  color: var(--color-error);
  font-size: 25rpx;
  font-weight: 750;
}

.emergency-notice > text:nth-child(2) {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 21rpx;
  line-height: 34rpx;
}

.contact-button {
  width: 100%;
  height: 76rpx;
  margin-top: 18rpx;
  border-radius: 20rpx;
  color: #ffffff;
  background: var(--color-error);
  font-size: 24rpx;
  font-weight: 700;
}

.field-hint {
  display: block;
  margin-top: 9rpx;
  color: var(--color-text-tertiary);
  font-size: 19rpx;
  text-align: right;
}

.evidence-tip {
  display: block;
  margin-top: -8rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
  line-height: 32rpx;
}

.evidence-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.evidence-item,
.add-evidence {
  position: relative;
  height: 154rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.evidence-item image {
  width: 100%;
  height: 100%;
}

.remove-evidence {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  min-width: 48rpx;
  max-width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #ffffff;
  background: rgba(23, 32, 51, 0.72);
  font-size: 30rpx;
}

.add-evidence {
  display: flex;
  flex-direction: column;
  border: 2rpx dashed #cbd5e3;
  color: var(--color-text-secondary);
  background: var(--color-page);
}

.add-evidence text {
  display: block;
}

.add-evidence text:first-child {
  color: var(--color-primary);
  font-size: 38rpx;
}

.add-evidence text:last-child {
  margin-top: 4rpx;
  font-size: 20rpx;
}
