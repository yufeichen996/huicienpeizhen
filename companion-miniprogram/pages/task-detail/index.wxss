.detail-page {
  padding-top: 20rpx;
}

.loading-state {
  padding: 180rpx 0;
  color: var(--color-text-secondary);
  text-align: center;
}

.status-card,
.section-card {
  padding: 28rpx;
}

.section-card {
  margin-top: 20rpx;
}

.status-top,
.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-top > text,
.section-title-row > text:last-child {
  color: var(--color-text-tertiary);
  font-size: 20rpx;
}

.status-title,
.status-desc {
  display: block;
}

.status-title {
  margin-top: 24rpx;
  font-size: 38rpx;
  font-weight: 750;
}

.status-desc {
  margin-top: 9rpx;
  color: var(--color-text-secondary);
  font-size: 23rpx;
  line-height: 38rpx;
}

.appointment-emphasis {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: var(--color-primary-soft);
}

.appointment-emphasis text {
  display: block;
  color: var(--color-primary);
  font-size: 24rpx;
  line-height: 38rpx;
  font-weight: 650;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 29rpx;
  font-weight: 750;
}

.detail-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
  border-bottom: 1rpx solid var(--color-divider);
  font-size: 23rpx;
}

.detail-row text:first-child {
  flex: none;
  color: var(--color-text-secondary);
}

.detail-row text:last-child {
  text-align: right;
  font-weight: 600;
}

.inline-action {
  width: 100%;
  height: 76rpx;
  margin-top: 14rpx;
  border-radius: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 24rpx;
  font-weight: 700;
}

.privacy-tip {
  padding: 24rpx;
  border-radius: 20rpx;
  background: var(--color-page);
}

.privacy-tip text {
  display: block;
}

.privacy-tip text:first-child {
  font-size: 25rpx;
  font-weight: 700;
}

.privacy-tip text:last-child {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  line-height: 36rpx;
}

.need-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.need-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  font-size: 21rpx;
}

.remark {
  display: block;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  color: var(--color-text-secondary);
  background: var(--color-page);
  font-size: 23rpx;
  line-height: 38rpx;
}

.boundary-item {
  min-height: 70rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  line-height: 36rpx;
}

.boundary-item view {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  flex: none;
  border-radius: 50%;
  background: var(--color-primary);
}

.timeline-item {
  min-height: 94rpx;
  display: flex;
  gap: 18rpx;
}

.timeline-rail {
  width: 24rpx;
  position: relative;
  display: flex;
  justify-content: center;
}

.timeline-dot {
  z-index: 1;
  width: 20rpx;
  height: 20rpx;
  margin-top: 5rpx;
  border: 5rpx solid #ffffff;
  border-radius: 50%;
  background: var(--color-divider);
  box-shadow: 0 0 0 2rpx var(--color-divider);
}

.timeline-line {
  position: absolute;
  top: 27rpx;
  bottom: -4rpx;
  width: 2rpx;
  background: var(--color-divider);
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-item.done .timeline-dot,
.timeline-item.current .timeline-dot {
  background: var(--color-success);
  box-shadow: 0 0 0 2rpx var(--color-success);
}

.timeline-item.current .timeline-dot {
  background: var(--color-primary);
  box-shadow: 0 0 0 2rpx var(--color-primary);
}

.timeline-copy text {
  display: block;
}

.timeline-copy text:first-child {
  font-size: 24rpx;
  font-weight: 650;
}

.timeline-copy text:last-child {
  margin-top: 6rpx;
  color: var(--color-text-tertiary);
  font-size: 20rpx;
}

.timeline-item.pending .timeline-copy {
  color: var(--color-text-tertiary);
}

.exception-row {
  min-height: 94rpx;
  padding: 14rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-top: 1rpx solid var(--color-divider);
}

.exception-row view {
  min-width: 0;
}

.exception-row text {
  display: block;
}

.exception-row view text:first-child {
  font-size: 22rpx;
  font-weight: 700;
}

.exception-row view text:last-child {
  margin-top: 6rpx;
  overflow: hidden;
  color: var(--color-text-secondary);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exception-row > text {
  flex: none;
  color: var(--color-warning);
  font-size: 20rpx;
}

.expense-row {
  min-height: 96rpx;
  padding: 14rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-top: 1rpx solid var(--color-divider);
}

.expense-row > view {
  min-width: 0;
}

.expense-row > view:last-child {
  flex: none;
  text-align: right;
}

.expense-row text {
  display: block;
}

.expense-row > view:first-child text:first-child,
.expense-row > view:last-child text:first-child {
  font-size: 23rpx;
  font-weight: 700;
}

.expense-row > view:first-child text:last-child,
.expense-row > view:last-child text:last-child {
  margin-top: 6rpx;
  color: var(--color-text-secondary);
  font-size: 19rpx;
}
