.exceptions-page {
  padding-top: 20rpx;
}

.exception-summary {
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.exception-summary view {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.exception-summary view text:first-child {
  color: var(--color-error);
  font-size: 42rpx;
  font-weight: 750;
}

.exception-summary view text:last-child,
.exception-summary > text {
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.filter-bar {
  margin-top: 20rpx;
  padding: 7rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-radius: 22rpx;
  background: var(--color-divider);
}

.filter-bar view {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 17rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  font-weight: 650;
}

.filter-bar view.active {
  color: var(--color-primary);
  background: #ffffff;
}

.loading-state {
  padding: 160rpx 0;
  color: var(--color-text-secondary);
  text-align: center;
}

.exception-list {
  margin-top: 18rpx;
}

.ticket-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
}

.ticket-head,
.ticket-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.urgency-chip {
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 700;
}

.urgency-chip.gray {
  color: var(--color-text-secondary);
  background: var(--color-divider);
}

.urgency-chip.orange {
  color: var(--color-warning);
  background: var(--color-warning-soft);
}

.urgency-chip.red {
  color: var(--color-error);
  background: var(--color-error-soft);
}

.ticket-head > text {
  color: var(--color-text-tertiary);
  font-size: 19rpx;
}

.ticket-category,
.ticket-desc {
  display: block;
}

.ticket-category {
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 750;
}

.ticket-desc {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  line-height: 36rpx;
}

.ticket-meta {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-divider);
  color: var(--color-text-tertiary);
  font-size: 19rpx;
}

.ticket-meta text:last-child {
  color: var(--color-primary);
  font-weight: 650;
}

.resolution {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: var(--color-success-soft);
}

.resolution text {
  display: block;
}

.resolution text:first-child {
  color: var(--color-success);
  font-size: 20rpx;
  font-weight: 700;
}

.resolution text:last-child {
  margin-top: 6rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
  line-height: 33rpx;
}

.ticket-task-link {
  min-width: 0 !important;
  width: auto !important;
  max-width: 100%;
  height: 70rpx;
  margin-top: 10rpx;
  margin-left: 0 !important;
  margin-right: auto !important;
  padding: 0 12rpx 0 0;
  justify-content: flex-start !important;
  color: var(--color-primary);
  font-size: 21rpx;
  font-weight: 650;
  text-align: left !important;
}

.empty-card {
  margin-top: 18rpx;
  padding: 82rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-mark {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background: var(--color-success-soft);
}

.empty-mark view {
  width: 28rpx;
  height: 14rpx;
  border-left: 6rpx solid var(--color-success);
  border-bottom: 6rpx solid var(--color-success);
  transform: rotate(-45deg);
}

.empty-title {
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 9rpx;
  color: var(--color-text-secondary);
  font-size: 21rpx;
  line-height: 34rpx;
}

.platform-button {
  width: 100%;
  height: 84rpx;
  margin-top: 22rpx;
  border-radius: 22rpx;
  color: var(--color-primary);
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}
