.settlements-page {
  padding-top: 20rpx;
}

.loading-state {
  padding: 180rpx 0;
  color: var(--color-text-secondary);
  text-align: center;
}

.amount-card {
  padding: 34rpx;
  border-radius: 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1261d3, #2b7ee7);
  box-shadow: 0 18rpx 42rpx rgba(18, 97, 211, 0.2);
}

.amount-card > text {
  display: block;
}

.amount-card > text:first-child {
  color: rgba(255, 255, 255, 0.76);
  font-size: 22rpx;
}

.amount-card > text:nth-child(2) {
  margin-top: 8rpx;
  font-size: 52rpx;
  font-weight: 750;
  font-variant-numeric: tabular-nums;
}

.month-paid {
  margin-top: 28rpx;
  padding-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid rgba(255, 255, 255, 0.22);
}

.month-paid text {
  font-size: 22rpx;
}

.month-paid text:last-child {
  font-weight: 700;
}

.amount-note {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 19rpx;
}

.section-head {
  margin: 34rpx 4rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-head text:first-child {
  font-size: 29rpx;
  font-weight: 750;
}

.section-head text:last-child {
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.settlement-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
}

.record-head,
.record-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-head > text {
  color: var(--color-text-tertiary);
  font-size: 19rpx;
}

.record-period {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  font-weight: 700;
}

.record-main {
  margin-top: 22rpx;
  padding: 20rpx 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1rpx solid var(--color-divider);
  border-bottom: 1rpx solid var(--color-divider);
}

.record-main view {
  text-align: center;
  border-right: 1rpx solid var(--color-divider);
}

.record-main view:last-child {
  border-right: 0;
}

.record-main text {
  display: block;
}

.record-main text:first-child {
  font-size: 25rpx;
  font-weight: 750;
  font-variant-numeric: tabular-nums;
}

.record-main text:last-child {
  margin-top: 5rpx;
  color: var(--color-text-secondary);
  font-size: 18rpx;
}

.record-foot {
  min-height: 66rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.record-foot text:last-child {
  color: var(--color-primary);
  font-weight: 650;
}

.settlement-notice {
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 22rpx;
  background: var(--color-primary-soft);
}

.settlement-notice > text {
  display: block;
}

.settlement-notice > text:first-child {
  color: var(--color-primary);
  font-size: 23rpx;
  font-weight: 700;
}

.settlement-notice > text:nth-child(2) {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 20rpx;
  line-height: 34rpx;
}

.finance-link {
  min-width: 0 !important;
  width: auto !important;
  max-width: 100%;
  height: 72rpx;
  margin-top: 12rpx;
  margin-left: 0 !important;
  margin-right: auto !important;
  padding: 0 12rpx 0 0;
  justify-content: flex-start !important;
  color: var(--color-primary);
  font-size: 21rpx;
  font-weight: 650;
  text-align: left !important;
}
