@import "/styles/tokens.wxss";.bar{display:flex;align-items:center;height:82rpx;padding:0 18rpx;border-radius:22rpx;background:#fff;box-shadow:var(--shadow-card)}.icon{width:26rpx;height:26rpx;margin-right:16rpx;border:4rpx solid var(--color-primary);border-radius:50%;position:relative}.icon:after{content:"";position:absolute;right:-9rpx;bottom:-6rpx;width:12rpx;height:4rpx;border-radius:2rpx;background:var(--color-primary);transform:rotate(45deg)}input{flex:1;font-size:26rpx}.bar button{width:52rpx;height:52rpx;border-radius:50%;background:var(--color-page);color:var(--color-text-secondary);font-size:30rpx}
