@import "/styles/tokens.wxss";

:host {
  display: block;
  width: 750rpx;
  max-width: 100vw;
}

.nav {
  position: relative;
  width: 750rpx;
  max-width: 100vw;
  box-sizing: border-box;
  overflow: visible;
}

.nav-content {
  position: relative;
  width: 750rpx;
  max-width: 100vw;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.nav-copy {
  position: absolute;
  top: 0;
  bottom: 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  pointer-events: none;
}

.nav-copy-leading {
  align-items: flex-start;
  text-align: left;
}

.back-button {
  position: absolute;
  z-index: 2;
  left: 16rpx;
  top: 50%;
  width: 88rpx;
  min-width: 88rpx;
  max-width: 88rpx;
  height: 88rpx;
  flex: 0 0 88rpx;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  color: var(--color-text-primary);
  background: transparent;
  line-height: 1;
  transform: translateY(-50%);
}

.back-button::after,
.message-button::after {
  border: 0;
}

.back-button:active {
  transform: translateY(-50%) scale(0.985);
}

.back-glyph {
  width: 20rpx;
  height: 20rpx;
  border-bottom: 5rpx solid var(--color-text-tertiary);
  border-left: 5rpx solid var(--color-text-tertiary);
  transform: translateX(3rpx) rotate(45deg);
}

.eyebrow {
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
  line-height: 34rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.nav-title {
  display: block;
  max-width: 100%;
  margin-top: 4rpx;
  overflow: hidden;
  color: var(--color-text-primary);
  font-size: var(--font-nav);
  line-height: 44rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-button {
  position: absolute;
  z-index: 2;
  top: 50%;
  width: 76rpx;
  min-width: 76rpx;
  max-width: 76rpx;
  height: 76rpx;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  flex: 0 0 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  color: var(--color-text-primary);
  background: var(--color-card);
  box-shadow: var(--shadow-card);
  line-height: 1;
  transform: translateY(-50%);
}

.message-button:active {
  transform: translateY(-50%) scale(0.985);
}

.message-icon {
  font-size: 24rpx;
}

.unread-dot {
  position: absolute;
  top: 13rpx;
  right: 13rpx;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
  background: var(--color-error);
}
