<view class="card"><view class="head" bindtap="onDetail"><order-status text="{{order.statusText}}" color="{{order.statusColor}}"/><text class="number">{{order.orderNo}}</text></view><view class="body" bindtap="onDetail"><text class="service">{{order.serviceName}}</text><text class="hospital">{{order.hospitalName}} · {{order.departmentName}}</text><text class="date">{{order.dateText}}</text><view class="companion"><image wx:if="{{order.companionAvatar}}" src="{{order.companionAvatar}}"/><text>{{order.companionText}}</text></view><view class="amount"><text>{{order.amountLabel}}</text><text>¥{{order.amountText}}</text></view><text class="description">{{order.statusDescription}}</text></view><view class="footer"><order-actions actions="{{order.actions}}" busy="{{busy}}" bindaction="onAction"/></view></view>
