@import "/styles/tokens.wxss";.card{margin-bottom:22rpx;border:1rpx solid rgba(60,60,67,.06);border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card);overflow:hidden}.head{display:flex;align-items:center;justify-content:space-between;padding:24rpx 26rpx;border-bottom:1rpx solid var(--color-divider)}.number{color:var(--color-text-tertiary);font-size:20rpx}.body{padding:26rpx}.service,.hospital,.date,.description{display:block}.service{font-size:32rpx;font-weight:750}.hospital{margin-top:14rpx;font-weight:600}.date{margin-top:9rpx;color:var(--color-text-secondary);font-size:24rpx}.companion{display:flex;align-items:center;gap:12rpx;margin-top:20rpx;color:var(--color-text-secondary);font-size:23rpx}.companion image{width:44rpx;height:44rpx;border-radius:50%;background:var(--color-primary-soft)}.amount{display:flex;align-items:baseline;justify-content:flex-end;gap:10rpx;margin-top:-34rpx}.amount text:first-child{color:var(--color-text-secondary);font-size:22rpx}.amount text:last-child{color:var(--color-primary);font-size:34rpx;font-weight:750}.description{margin-top:22rpx;padding:18rpx 20rpx;border-radius:16rpx;background:var(--color-page);color:var(--color-text-secondary);font-size:22rpx;line-height:1.55}.footer{padding:0 26rpx 24rpx}
