@import "/styles/tokens.wxss";.node{display:flex;min-height:108rpx}.rail{position:relative;width:42rpx;flex:0 0 42rpx}.dot{position:relative;z-index:1;width:22rpx;height:22rpx;margin-top:5rpx;border:5rpx solid #fff;border-radius:50%;background:#c7c7cc;box-shadow:0 0 0 2rpx #c7c7cc}.line{position:absolute;top:28rpx;bottom:0;left:10rpx;width:2rpx;background:#d8d8dd}.copy{padding:0 0 28rpx 12rpx}.title,.desc,.time{display:block}.title{color:var(--color-text-tertiary);font-weight:650}.desc,.time{margin-top:7rpx;color:var(--color-text-tertiary);font-size:22rpx}.done .dot{background:var(--color-green);box-shadow:0 0 0 2rpx var(--color-green)}.done .line{background:var(--color-primary)}.done .title{color:var(--color-text-primary)}.current .dot{background:var(--color-primary);box-shadow:0 0 0 3rpx var(--color-primary)}.current .title{color:var(--color-primary);font-weight:750}
