@import "/styles/tokens.wxss";.card{margin-bottom:20rpx;padding:26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.head{display:flex;align-items:center;gap:12rpx}.name{font-size:31rpx;font-weight:750}.default,.relation{padding:5rpx 11rpx;border-radius:99rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:19rpx}.relation{background:var(--color-page);color:var(--color-text-secondary)}.meta{display:block;margin-top:14rpx;color:var(--color-text-secondary);font-size:24rpx}.actions{display:flex;justify-content:flex-end;gap:12rpx;margin-top:22rpx;padding-top:20rpx;border-top:1rpx solid var(--color-divider)}.actions button{padding:15rpx 22rpx;border-radius:17rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:22rpx}.actions .danger{background:#fff0ef;color:var(--color-error)}
