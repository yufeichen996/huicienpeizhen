<view class="card"><view class="head"><text class="name">{{patient.name}}</text><text wx:if="{{patient.isDefault}}" class="default">默认</text><text class="relation">{{patient.relationshipText}}</text></view><text class="meta">{{patient.genderText}} · {{patient.age}}岁 · {{patient.phoneMasked}}</text><view class="actions"><button wx:if="{{!patient.isDefault}}" bindtap="setDefault">设为默认</button><button bindtap="edit">编辑</button><button class="danger" bindtap="remove">删除</button></view></view>
