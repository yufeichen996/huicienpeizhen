@import "/styles/tokens.wxss";.review{padding:24rpx 0;border-bottom:1rpx solid var(--color-divider)}.review:last-child{border:0}.review>view{display:flex;justify-content:space-between;font-weight:700}.review>view text:last-child{color:var(--color-orange)}.tags,.content,.date{display:block;margin-top:10rpx}.tags{color:var(--color-primary);font-size:21rpx}.content{color:var(--color-text-secondary);font-size:24rpx;line-height:1.6}.date{color:var(--color-text-tertiary);font-size:20rpx}
