@import "/styles/tokens.wxss";.card{margin-bottom:18rpx;padding:24rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.head{display:flex;align-items:center;gap:18rpx}.icon{display:flex;align-items:center;justify-content:center;width:70rpx;height:70rpx;border-radius:20rpx;background:var(--color-primary-soft);color:var(--color-primary);font-weight:750}.copy{flex:1}.name,.meta,.address{display:block}.name{font-size:29rpx;font-weight:750}.meta{margin-top:7rpx;color:var(--color-text-secondary);font-size:22rpx}.address{margin-top:16rpx;color:var(--color-text-secondary);font-size:23rpx}.tags{display:flex;flex-wrap:wrap;gap:9rpx;margin-top:14rpx}.tags text{padding:6rpx 11rpx;border-radius:99rpx;background:var(--color-page);color:var(--color-text-secondary);font-size:19rpx}.foot{display:flex;align-items:center;justify-content:space-between;margin-top:18rpx;padding-top:18rpx;border-top:1rpx solid var(--color-divider);color:var(--color-primary);font-size:21rpx}.foot button{padding:15rpx 20rpx;border-radius:16rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:22rpx}
