<view class="card"><view class="head"><view class="icon">{{hospital.icon}}</view><view class="copy" bindtap="detail"><text class="name">{{hospital.name}}</text><text class="meta">{{hospital.level}} · {{hospital.district}}</text></view><favorite-button favorited="{{hospital.favorited}}" bindtoggle="favorite"/></view><text class="address">{{hospital.address}}</text><view class="tags"><text wx:for="{{hospital.hotDepartments}}" wx:key="*this">{{item}}</text></view><view class="foot"><text>{{hospital.serviceText}}</text><button bindtap="detail">查看详情</button></view></view>
