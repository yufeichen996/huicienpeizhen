@import "/styles/tokens.wxss";.card{padding:24rpx 26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.head{display:flex;justify-content:space-between;font-weight:700}.head text:last-child{color:var(--color-primary);font-size:23rpx;font-weight:500}.items{display:flex;justify-content:space-between;margin-top:26rpx}.item{position:relative;display:flex;align-items:center;flex-direction:column;gap:10rpx;width:25%;font-size:22rpx}.icon{display:flex;align-items:center;justify-content:center;width:60rpx;height:60rpx;border-radius:18rpx;background:var(--color-primary-soft);color:var(--color-primary);font-weight:750}.badge{position:absolute;top:-7rpx;right:18rpx;min-width:31rpx;height:31rpx;padding:0 8rpx;border:3rpx solid #fff;border-radius:99rpx;background:var(--color-error);color:#fff;font-size:18rpx;line-height:26rpx;text-align:center}
