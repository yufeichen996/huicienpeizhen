@import "/styles/tokens.wxss";

.hospital-chip {
  min-width: 220rpx;
  height: 92rpx;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  border: 1rpx solid rgba(60, 60, 67, 0.08);
  border-radius: var(--radius-card);
  background: var(--color-card);
  box-shadow: var(--shadow-card);
}
.hospital-icon { width: 52rpx; height: 52rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 16rpx; background: var(--color-primary-soft); }
.hospital-name { margin-left: 14rpx; color: var(--color-text-primary); font-size: 25rpx; line-height: 34rpx; font-weight: 600; white-space: nowrap; }
