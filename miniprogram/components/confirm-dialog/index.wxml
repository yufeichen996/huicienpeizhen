<view wx:if="{{visible}}" class="mask" bindtap="cancel" catchtouchmove="stop"><view class="sheet" catchtap="stop"><text class="title">{{title}}</text><text class="message">{{message}}</text><view wx:if="{{options.length}}" class="options"><view class="option {{selected === item ? 'active' : ''}}" wx:for="{{options}}" wx:key="*this" data-value="{{item}}" bindtap="select"><text>{{item}}</text><text>{{selected === item ? '✓' : ''}}</text></view></view><view class="buttons"><button bindtap="cancel">暂不操作</button><button class="confirm {{dangerous ? 'danger' : ''}}" loading="{{loading}}" bindtap="confirm">{{confirmText}}</button></view></view></view>
