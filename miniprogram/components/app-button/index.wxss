@import "/styles/tokens.wxss";.app-button{min-width:128rpx;height:var(--button-height);padding:0 32rpx!important;display:inline-flex!important;align-items:center;justify-content:center;gap:12rpx;border-radius:var(--radius-button);font-size:28rpx;font-weight:650;transition:opacity 160ms ease,transform 160ms ease}.app-button:active{opacity:.72;transform:scale(.985)}.block{width:100%!important}.size-small{height:var(--button-height-small);font-size:26rpx}.type-primary{color:#fff;background:var(--color-primary);box-shadow:0 10rpx 24rpx rgba(0,122,255,.18)}.type-secondary{color:var(--color-primary);background:var(--color-primary-soft)}.type-text{color:var(--color-primary);background:transparent}.type-danger{color:var(--color-error);background:rgba(255,59,48,.08)}.app-button[disabled]{color:var(--color-text-tertiary);background:var(--color-divider);box-shadow:none;opacity:.7}
