@import "/styles/tokens.wxss";.header{display:flex;align-items:center;gap:22rpx;padding:28rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.avatar{width:104rpx;height:104rpx;border-radius:50%;background:var(--color-primary-soft)}.copy{flex:1;min-width:0}.name,.phone{display:block}.name{font-size:32rpx;font-weight:750}.phone{margin-top:10rpx;color:var(--color-text-secondary);font-size:23rpx;line-height:1.45}.arrow{color:var(--color-text-tertiary);font-size:42rpx}
