@import "/styles/tokens.wxss";.card{margin-bottom:18rpx;padding:24rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.top{display:flex;align-items:flex-start;gap:20rpx}.icon{display:flex;align-items:center;justify-content:center;width:78rpx;height:78rpx;border-radius:22rpx;font-size:29rpx;font-weight:750}.copy{flex:1;min-width:0}.name{font-size:30rpx;font-weight:750}.recommend{margin-left:10rpx;padding:4rpx 10rpx;border-radius:99rpx;background:var(--color-orange-soft);color:var(--color-orange);font-size:18rpx}.desc,.meta{display:block;margin-top:8rpx;color:var(--color-text-secondary);font-size:23rpx}.meta{color:var(--color-text-tertiary);font-size:21rpx}.bottom{display:flex;align-items:center;justify-content:space-between;margin-top:20rpx;padding-top:18rpx;border-top:1rpx solid var(--color-divider);color:var(--color-text-secondary);font-size:21rpx}.bottom>text>text{color:var(--color-primary);font-size:32rpx;font-weight:750}.bottom button{padding:17rpx 24rpx;border-radius:18rpx;background:var(--color-primary);color:#fff;font-size:23rpx;font-weight:700}
