<view class="card"><view class="top" bindtap="detail"><view class="icon" style="color:{{service.themeColor}};background:{{service.themeBackground}}">{{service.icon}}</view><view class="copy"><view><text class="name">{{service.name}}</text><text wx:if="{{service.isRecommended}}" class="recommend">推荐</text></view><text class="desc">{{service.shortDescription}}</text><text class="meta">约 {{service.durationMinutes}} 分钟</text></view><favorite-button favorited="{{service.favorited}}" bindtoggle="favorite"/></view><view class="bottom"><text><text>¥{{service.priceText}}</text> {{service.priceUnit}}</text><button bindtap="book">立即预约</button></view></view>
