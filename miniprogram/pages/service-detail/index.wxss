@import "../catalog/shared.wxss";.detail-hero{display:flex;align-items:flex-start;gap:20rpx;padding:26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.service-icon{display:flex;align-items:center;justify-content:center;width:88rpx;height:88rpx;border-radius:25rpx;font-size:32rpx;font-weight:750}.hero-copy{flex:1}.hero-copy>text{display:block}.hero-copy>text:first-child{font-size:35rpx;font-weight:750}.hero-copy>text:nth-child(2){margin-top:8rpx;color:var(--color-text-secondary);font-size:23rpx}.hero-copy>view{display:flex;gap:20rpx;margin-top:15rpx;color:var(--color-text-secondary);font-size:21rpx}.hero-copy>view text:first-child{color:var(--color-primary);font-size:27rpx;font-weight:700}.description{display:block;margin-top:20rpx;padding:24rpx;border-radius:22rpx;background:#fff;color:var(--color-text-secondary);font-size:24rpx;line-height:1.7}.feature-grid{display:grid;grid-template-columns:1fr 1fr;gap:12rpx}.feature-grid view{display:flex;gap:10rpx;padding:18rpx;border-radius:18rpx;background:#fff;font-size:22rpx}.feature-grid view text:first-child{color:var(--color-green)}.list text{display:block;padding:17rpx 0;border-bottom:1rpx solid var(--color-divider);font-size:23rpx}.list text:last-child{border:0}.excluded text{color:var(--color-text-secondary)}.steps>view{display:flex;gap:18rpx;padding:18rpx 0}.steps>view>text{display:flex;align-items:center;justify-content:center;width:42rpx;height:42rpx;border-radius:50%;background:var(--color-primary);color:#fff;font-size:21rpx}.steps view view{flex:1}.steps view view text{display:block}.steps view view text:first-child{font-weight:700}.steps view view text:last-child{margin-top:6rpx;color:var(--color-text-secondary);font-size:21rpx}.tags{display:flex;flex-wrap:wrap;gap:12rpx}.tags text{padding:15rpx 20rpx;border-radius:99rpx;background:#fff;color:var(--color-primary);font-size:22rpx}.hospital-chips{display:flex;gap:14rpx}.hospital-chips view{display:flex;align-items:center;gap:10rpx;min-width:210rpx;padding:18rpx;border-radius:19rpx;background:#fff}.hospital-chips view text:first-child{display:flex;align-items:center;justify-content:center;width:45rpx;height:45rpx;border-radius:13rpx;background:var(--color-primary-soft);color:var(--color-primary)}
