<view class="catalog-page with-action"><custom-navbar eyebrow="服务详情" title="{{service ? service.name : '陪诊服务'}}"/><view wx:if="{{service}}" class="catalog-content"><view class="detail-hero"><view class="service-icon" style="color:{{service.themeColor}};background:{{service.themeBackground}}">{{service.icon}}</view><view class="hero-copy"><text>{{service.name}}</text><text>{{service.shortDescription}}</text><view><text>¥{{priceText}} {{service.priceUnit}}</text><text>约 {{service.durationMinutes}} 分钟</text></view></view><favorite-button favorited="{{favorited}}" label bindtoggle="favorite"/></view><text class="description">{{service.description}}</text><view class="section-title"><text>服务保障</text></view><view class="feature-grid"><view wx:for="{{service.features}}" wx:key="*this"><text>✓</text><text>{{item}}</text></view></view><view class="section-title"><text>服务内容</text></view><view class="group-card list"><text wx:for="{{service.includedItems}}" wx:key="*this">✓ {{item}}</text></view><view class="section-title"><text>不包含内容</text></view><view class="group-card list excluded"><text wx:for="{{service.excludedItems}}" wx:key="*this">— {{item}}</text></view><view class="section-title"><text>服务流程</text></view><view class="group-card steps"><view wx:for="{{service.processSteps}}" wx:key="title"><text>{{index + 1}}</text><view><text>{{item.title}}</text><text>{{item.description}}</text></view></view></view><view class="section-title"><text>适用人群</text></view><view class="tags"><text wx:for="{{service.suitableFor}}" wx:key="*this">{{item}}</text></view><view class="section-title"><text>注意事项</text></view><view class="group-card list notices"><text wx:for="{{service.notices}}" wx:key="*this">{{index + 1}}. {{item}}</text></view><view class="section-title"><text>支持医院</text></view><scroll-view class="hospital-scroll" scroll-x show-scrollbar="false"><view class="hospital-chips"><view wx:for="{{hospitals}}" wx:key="id" data-id="{{item.id}}" bindtap="hospital"><text>{{item.icon}}</text><text>{{item.shortName}}</text></view></view></scroll-view><view class="section-title"><text>常见问题</text></view><view class="group-card"><faq-list items="{{service.faq}}"/></view></view><view wx:if="{{missing}}" class="loading">未找到该服务</view><view wx:if="{{service}}" class="fixed-actions"><button bindtap="customer">咨询客服</button><button bindtap="book">立即预约</button></view><login-sheet visible="{{loginVisible}}" bindclose="closeLogin" bindsuccess="loginSuccess"/></view>
