<view class="safe-page orders-page"><custom-navbar eyebrow="订单中心" title="我的订单"/><view class="orders-content"><scroll-view class="filter-scroll" scroll-x show-scrollbar="false"><view class="filters"><text class="filter {{activeFilter === item.id ? 'active' : ''}}" wx:for="{{filters}}" wx:key="id" data-id="{{item.id}}" bindtap="selectFilter">{{item.text}}</text></view></scroll-view><view wx:if="{{filterNotice}}" class="shortcut-notice">已从“我的”筛选：{{filterNotice}}</view>
<view wx:if="{{loading}}" class="state-card"><view class="spinner"></view><text>正在加载订单…</text></view><view wx:elif="{{loadError}}" class="state-card"><text class="state-title">订单加载失败</text><text class="state-note">请检查后重试</text><button bindtap="retry">重新加载</button></view>
<view wx:elif="{{orders.length}}"><order-card wx:for="{{orders}}" wx:key="id" order="{{item}}" busy="{{busy}}" binddetail="onDetail" bindaction="onAction"/></view>
<view wx:else class="state-card"><text class="empty-icon">单</text><text class="state-title">暂无相关订单</text><text class="state-note">换个筛选条件，或预约一项陪诊服务</text><button bindtap="onBook">去预约服务</button></view></view>
<confirm-dialog visible="{{dialog === 'cancel'}}" title="取消订单" message="取消后无法恢复，请选择取消原因。" options="{{cancelReasons}}" selected="{{selectedReason}}" confirm-text="确认取消" dangerous loading="{{busy}}" bindselect="selectReason" bindcancel="closeDialog" bindconfirm="confirmDialog"/>
<confirm-dialog visible="{{dialog === 'pay'}}" title="模拟支付" message="本阶段仅模拟支付结果，不会调用真实微信支付。" confirm-text="确认支付" loading="{{busy}}" bindcancel="closeDialog" bindconfirm="confirmDialog"/>
<confirm-dialog visible="{{dialog === 'delete'}}" title="删除记录" message="删除后将无法在订单列表中找回。" confirm-text="确认删除" dangerous loading="{{busy}}" bindcancel="closeDialog" bindconfirm="confirmDialog"/><login-sheet visible="{{loginVisible}}" bindclose="closeLogin" bindsuccess="loginSuccess"/></view>
