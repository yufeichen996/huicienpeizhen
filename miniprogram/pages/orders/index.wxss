@import "/styles/tokens.wxss";
.orders-page { background: var(--color-page); }
.orders-content { padding: 16rpx var(--page-gutter) 40rpx; }
.filter-scroll { width: 100%; margin-bottom: 24rpx; }
.filters { display: inline-flex; gap: 5rpx; min-width: 100%; padding: 7rpx; border-radius: 20rpx; background: #e5e5ea; }
.filter { flex: 1; min-width: 112rpx; padding: 18rpx 13rpx; border-radius: 15rpx; color: var(--color-text-secondary); font-size: 23rpx; text-align: center; white-space: nowrap; }
.filter.active { background: #fff; color: var(--color-primary); font-weight: 700; box-shadow: 0 3rpx 12rpx rgba(0,0,0,.08); }
.shortcut-notice { margin: -8rpx 0 20rpx; padding: 16rpx 20rpx; border-radius: 16rpx; background: var(--color-primary-soft); color: var(--color-primary); font-size: 22rpx; }
.state-card { display: flex; align-items: center; flex-direction: column; margin-top: 50rpx; padding: 70rpx 28rpx; border-radius: var(--radius-card); background: #fff; box-shadow: var(--shadow-card); text-align: center; }
.state-title { margin-top: 24rpx; font-size: 32rpx; font-weight: 700; }
.state-note { margin-top: 12rpx; color: var(--color-text-secondary); font-size: 24rpx; }
.state-card button { width: 280rpx; height: 80rpx; margin-top: 32rpx; border-radius: 22rpx; background: var(--color-primary); color: #fff; font-weight: 700; }
.empty-icon { display: flex; align-items: center; justify-content: center; width: 88rpx; height: 88rpx; border-radius: 26rpx; background: var(--color-primary-soft); color: var(--color-primary); font-weight: 750; }
.spinner { width: 44rpx; height: 44rpx; margin-bottom: 20rpx; border: 5rpx solid #d8eaff; border-top-color: var(--color-primary); border-radius: 50%; animation: spin .8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
