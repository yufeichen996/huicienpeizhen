@import "../catalog/shared.wxss";.profile-hero{display:flex;align-items:center;gap:20rpx;padding:26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.profile-hero>image{width:108rpx;height:108rpx;border-radius:50%;background:var(--color-primary-soft)}.profile-hero>view{flex:1}.profile-hero>view>view{display:flex;align-items:center;gap:10rpx}.profile-hero>view>view text:first-child{font-size:34rpx;font-weight:750}.profile-hero>view>view text:last-child{padding:5rpx 10rpx;border-radius:99rpx;background:var(--color-green-soft);color:var(--color-green);font-size:17rpx}.profile-hero>view>text{display:block;margin-top:8rpx;color:var(--color-text-secondary);font-size:22rpx}.tags,.dates{display:flex;flex-wrap:wrap;gap:12rpx}.tags text,.dates text{padding:15rpx 20rpx;border-radius:99rpx;background:#fff;color:var(--color-primary);font-size:22rpx}.dates text{color:var(--color-text-primary)}.intro{padding:26rpx;color:var(--color-text-secondary);font-size:24rpx;line-height:1.75}.link-list>view{display:flex;align-items:center;gap:16rpx;margin-bottom:12rpx;padding:19rpx;border-radius:19rpx;background:#fff}.service-icon{display:flex;align-items:center;justify-content:center;width:55rpx;height:55rpx;border-radius:16rpx;background:var(--color-primary-soft);color:var(--color-primary);font-weight:700}.link-list>view>view{flex:1}.link-list>view>view text{display:block}.link-list>view>view text:first-child{font-weight:700}.link-list>view>view text:last-child{margin-top:6rpx;color:var(--color-text-secondary);font-size:21rpx}.link-list>view>text:last-child{color:var(--color-text-tertiary);font-size:35rpx}
