<view class="catalog-page with-action"><custom-navbar eyebrow="陪诊员资料" title="{{companion ? companion.name : '陪诊员'}}"/><view wx:if="{{companion}}" class="catalog-content"><view class="profile-hero"><image src="{{companion.avatar}}"/><view><view><text>{{companion.name}}</text><text wx:if="{{companion.verified}}">实名认证</text></view><text>★ {{companion.rating}} · {{companion.serviceCount}} 次服务</text><text>{{companion.responseText}}响应 · 从业{{companion.workingYears}}年</text></view><favorite-button favorited="{{favorited}}" label bindtoggle="favorite"/></view><view class="section-title"><text>专业标签</text></view><view class="tags"><text wx:for="{{companion.tags}}" wx:key="*this">{{item}}</text></view><view class="section-title"><text>个人简介</text></view><view class="group-card intro">{{companion.introduction}}</view><view class="section-title"><text>擅长服务</text></view><view class="link-list"><view wx:for="{{services}}" wx:key="id" data-id="{{item.id}}" bindtap="service"><text class="service-icon">{{item.icon}}</text><view><text>{{item.name}}</text><text>¥{{item.priceText}}起 · {{item.durationMinutes}}分钟</text></view><text>›</text></view></view><view class="section-title"><text>服务医院</text></view><view class="link-list"><view wx:for="{{hospitals}}" wx:key="id" data-id="{{item.id}}" bindtap="hospital"><text class="service-icon">{{item.icon}}</text><view><text>{{item.shortName}}</text><text>{{item.district}} · {{item.level}}</text></view><text>›</text></view></view><view class="section-title"><text>可预约日期</text></view><view class="dates"><text wx:for="{{companion.availableDates}}" wx:key="*this">{{item}}</text></view><view class="section-title"><text>用户评价（{{companion.reviewCount}}）</text></view><view class="group-card"><review-card wx:for="{{reviews}}" wx:key="id" review="{{item}}"/></view></view><view wx:if="{{missing}}" class="loading">未找到该陪诊员</view><view wx:if="{{companion}}" class="fixed-actions"><button bindtap="customer">咨询客服</button><button bindtap="book">立即预约 · ¥{{priceText}}起</button></view><login-sheet visible="{{loginVisible}}" bindclose="closeLogin" bindsuccess="loginSuccess"/></view>
