@import "/styles/tokens.wxss";.detail-page{min-height:100vh;background:var(--color-page)}.detail-content{padding:18rpx var(--page-gutter) calc(150rpx + env(safe-area-inset-bottom))}.status-hero{display:flex;align-items:center;flex-direction:column;padding:34rpx 26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card);text-align:center}.status-icon{display:flex;align-items:center;justify-content:center;width:78rpx;height:78rpx;margin-bottom:20rpx;border-radius:50%;background:var(--color-primary-soft);color:var(--color-primary);font-size:45rpx;font-weight:750}.status-hero>text{margin-top:14rpx;color:var(--color-text-secondary);font-size:24rpx;line-height:1.55}.section-title{display:block;margin:34rpx 4rpx 15rpx;font-size:29rpx;font-weight:700}.group-card{padding:12rpx 26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.row{display:flex;align-items:flex-start;justify-content:space-between;gap:30rpx;min-height:82rpx;padding:22rpx 0;border-bottom:1rpx solid var(--color-divider);font-size:24rpx}.row:last-child{border:0}.row>text:first-child{flex:0 0 150rpx;color:var(--color-text-secondary)}.row>text:last-child,.row>view{text-align:right}.discount{color:var(--color-green)}.total{font-size:29rpx;font-weight:700}.total text:last-child{color:var(--color-primary)}.copy{margin-left:14rpx;color:var(--color-primary)}.companion-box{display:flex;align-items:center;gap:18rpx;padding:24rpx}.companion-box image{width:86rpx;height:86rpx;border-radius:50%;background:var(--color-primary-soft)}.companion-box view{flex:1}.companion-name,.sub{display:block}.companion-name{font-weight:700}.sub{margin-top:7rpx;color:var(--color-text-tertiary);font-size:21rpx}.companion-box button{padding:15rpx 18rpx;border-radius:17rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:22rpx}.matching{padding:30rpx;color:var(--color-text-secondary);text-align:center}.review{padding:26rpx}.review text{display:block;margin:9rpx 0}.stars{color:var(--color-orange);font-size:28rpx;font-weight:700}.review-content{color:var(--color-text-secondary);line-height:1.6}.fixed-actions{position:fixed;z-index:30;right:0;bottom:0;left:0;padding:20rpx var(--page-gutter) calc(20rpx + env(safe-area-inset-bottom));border-top:1rpx solid var(--color-divider);background:rgba(255,255,255,.96)}.missing{display:flex;align-items:center;flex-direction:column;padding:160rpx 30rpx}.missing button{margin-top:30rpx;padding:24rpx 50rpx;border-radius:22rpx;background:var(--color-primary);color:#fff}
