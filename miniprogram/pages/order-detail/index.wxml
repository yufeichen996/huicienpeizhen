<view class="detail-page"><custom-navbar eyebrow="订单中心" title="订单详情"/><view wx:if="{{missing}}" class="missing"><text>未找到该订单</text><button bindtap="toOrders">返回订单列表</button></view><view wx:if="{{order}}" class="detail-content"><view class="status-hero"><view class="status-icon">{{order.status === 'COMPLETED' ? '✓' : order.status === 'CANCELLED' ? '×' : '·'}}</view><order-status text="{{order.statusText}}" color="{{order.statusColor}}"/><text>{{order.statusDescription}}</text></view>
<text class="section-title">订单进度</text><view class="group-card"><order-timeline items="{{order.timeline}}"/></view>
<text class="section-title">服务信息</text><view class="group-card"><view class="row"><text>服务项目</text><text>{{order.serviceName}}</text></view><view class="row"><text>服务说明</text><text>{{order.serviceDescription || '专业陪诊服务'}}</text></view><view class="row"><text>预计时长</text><text>{{order.serviceDuration}} 分钟</text></view><view class="row"><text>特殊需求</text><text>{{order.specialNeedsText}}</text></view></view>
<text class="section-title">就诊信息</text><view class="group-card"><view class="row"><text>医院</text><text>{{order.hospitalName}}</text></view><view class="row"><text>科室</text><text>{{order.departmentName}}</text></view><view class="row"><text>就诊时间</text><text>{{order.bookingDate}} {{order.bookingTime}}</text></view><view class="row"><text>就诊人</text><text>{{order.patientName}}</text></view><view class="row"><text>联系电话</text><text>{{order.patientPhone}}</text></view></view>
<text class="section-title">陪诊员信息</text><view class="group-card companion-box" wx:if="{{order.companionName}}"><image src="{{order.companionAvatar}}"/><view><text class="companion-name">{{order.companionName}} · ★{{order.companionRating}}</text><text class="sub">已完成 {{order.companionServiceCount}} 次服务</text></view><button bindtap="viewCompanion">查看资料</button></view><view wx:else class="group-card matching">平台正在匹配陪诊员</view>
<text class="section-title">费用信息</text><view class="group-card"><view class="row"><text>服务费</text><text>¥{{order.serviceFeeText}}</text></view><view class="row"><text>指定陪诊员费</text><text>¥{{order.companionFeeText}}</text></view><view class="row discount"><text>优惠金额</text><text>-¥{{order.discountText}}</text></view><view class="row total"><text>实付金额</text><text>¥{{order.paidText}}</text></view><view class="row"><text>支付状态</text><text>{{order.paymentStatusText}}</text></view></view>
<text class="section-title">订单信息</text><view class="group-card"><view class="row"><text>订单编号</text><view><text>{{order.orderNo}}</text><text class="copy" bindtap="copyOrderNo">复制</text></view></view><view class="row"><text>创建时间</text><text>{{order.createdAtText}}</text></view><view class="row"><text>支付时间</text><text>{{order.paidAtText || '未支付'}}</text></view><view class="row"><text>订单来源</text><text>汇慈恩陪诊小程序</text></view><view class="row"><text>支付方式</text><text>{{order.paymentMethod || '未支付'}}</text></view></view>
<view wx:if="{{order.cancelReason}}"><text class="section-title">取消信息</text><view class="group-card"><view class="row"><text>取消原因</text><text>{{order.cancelReason}}</text></view></view></view>
<view wx:if="{{order.review}}"><text class="section-title">我的评价</text><view class="group-card review"><text class="stars">★★★★★ {{order.review.overall}}.0</text><text>{{order.reviewTagsText}}</text><text class="review-content">{{order.review.content || '用户未填写文字评价'}}</text><text class="sub">{{order.review.anonymous ? '匿名评价' : order.patientName}}</text></view></view></view>
<view wx:if="{{order}}" class="fixed-actions"><order-actions actions="{{order.actions}}" busy="{{busy}}" bindaction="onAction"/></view>
<confirm-dialog visible="{{dialog === 'cancel'}}" title="取消订单" message="取消后无法恢复，请选择取消原因。" options="{{cancelReasons}}" selected="{{selectedReason}}" confirm-text="确认取消" dangerous loading="{{busy}}" bindselect="selectReason" bindcancel="closeDialog" bindconfirm="confirmDialog"/><confirm-dialog visible="{{dialog === 'pay'}}" title="模拟支付" message="本阶段仅模拟支付结果，不会调用真实微信支付。" confirm-text="确认支付" loading="{{busy}}" bindcancel="closeDialog" bindconfirm="confirmDialog"/><confirm-dialog visible="{{dialog === 'delete'}}" title="删除记录" message="删除后将无法恢复。" confirm-text="确认删除" dangerous loading="{{busy}}" bindcancel="closeDialog" bindconfirm="confirmDialog"/></view>
