<view class="catalog-page"><custom-navbar eyebrow="搜索“{{query}}”" title="{{title}}"/><view class="catalog-content"><view wx:if="{{items.length}}"><view class="all-row" wx:for="{{items}}" wx:key="id" data-id="{{item.id}}" bindtap="open"><image wx:if="{{type === 'companions'}}" src="{{item.avatar}}" lazy-load/><view wx:else class="type-icon">{{type === 'departments' ? '科' : item.icon}}</view><view class="copy"><text>{{item.name}}</text><text wx:if="{{type === 'services'}}">{{item.shortDescription}} · ¥{{item.priceText}}起</text><text wx:elif="{{type === 'hospitals'}}">{{item.level}} · {{item.district}}</text><text wx:elif="{{type === 'companions'}}">★{{item.rating}} · {{item.tags[0]}} · ¥{{item.priceFrom}}起</text><text wx:else>{{item.hospitalName}} · {{item.groupName}}</text></view><text class="arrow">›</text></view></view><empty-state wx:else title="暂无搜索结果" description="换个关键词试试"/></view></view>
