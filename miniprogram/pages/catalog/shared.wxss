@import "/styles/tokens.wxss";.catalog-page{min-height:100vh;padding-bottom:calc(44rpx + env(safe-area-inset-bottom));background:var(--color-page)}.catalog-page.with-action{padding-bottom:calc(145rpx + env(safe-area-inset-bottom))}.catalog-content{padding:18rpx var(--page-gutter) 40rpx}.section-title{display:flex;align-items:center;justify-content:space-between;margin:32rpx 4rpx 15rpx;font-size:29rpx;font-weight:700}.section-title text:last-child{color:var(--color-primary);font-size:22rpx;font-weight:500}.group-card{padding:8rpx 26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.fixed-actions{position:fixed;z-index:30;right:0;bottom:0;left:0;display:flex;gap:18rpx;padding:20rpx var(--page-gutter) calc(20rpx + env(safe-area-inset-bottom));border-top:1rpx solid var(--color-divider);background:rgba(255,255,255,.96)}.fixed-actions button{height:var(--button-height);border-radius:var(--radius-button);font-size:27rpx;font-weight:700}.fixed-actions button:first-child{width:210rpx;background:var(--color-primary-soft);color:var(--color-primary)}.fixed-actions button:last-child{flex:1;background:var(--color-primary);color:#fff}.filter-row{display:flex;gap:12rpx;margin:18rpx 0;overflow:hidden}.filter-row scroll-view{white-space:nowrap}.filter-chip{display:inline-flex;margin-right:10rpx;padding:15rpx 20rpx;border-radius:99rpx;background:#fff;color:var(--color-text-secondary);font-size:22rpx}.filter-chip.active{background:var(--color-primary);color:#fff}.loading{padding:100rpx 20rpx;color:var(--color-text-secondary);text-align:center}
