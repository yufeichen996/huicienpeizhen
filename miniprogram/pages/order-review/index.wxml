<view class="review-page"><custom-navbar eyebrow="订单中心" title="评价服务"/><view wx:if="{{order}}" class="content"><view class="summary"><text>{{order.serviceName}}</text><text>{{order.hospitalName}} · {{order.bookingDate}} {{order.bookingTime}}</text></view><view class="overall"><text>本次服务体验如何？</text><view class="stars"><text class="{{item.active ? 'active' : ''}}" wx:for="{{overallStars}}" wx:key="value" data-field="overall" data-value="{{item.value}}" bindtap="rate">★</text></view><text class="score">{{overall}}.0 分</text></view>
<view class="group"><view class="rating-row"><text>服务态度</text><view><text class="star-small {{item.active ? 'active' : ''}}" wx:for="{{attitudeStars}}" wx:key="value" data-field="attitude" data-value="{{item.value}}" bindtap="rate">★</text></view></view><view class="rating-row"><text>专业程度</text><view><text class="star-small {{item.active ? 'active' : ''}}" wx:for="{{professionalStars}}" wx:key="value" data-field="professional" data-value="{{item.value}}" bindtap="rate">★</text></view></view><view class="rating-row"><text>准时程度</text><view><text class="star-small {{item.active ? 'active' : ''}}" wx:for="{{punctualityStars}}" wx:key="value" data-field="punctuality" data-value="{{item.value}}" bindtap="rate">★</text></view></view></view>
<text class="section-title">印象标签</text><view class="tags"><text class="{{item.selected ? 'active' : ''}}" wx:for="{{tags}}" wx:key="value" data-value="{{item.value}}" bindtap="toggleTag">{{item.value}}</text></view><text class="section-title">文字评价</text><view class="textarea"><textarea maxlength="300" placeholder="分享本次陪诊体验，帮助我们做得更好" value="{{content}}" bindinput="onContent"/><text>{{content.length}}/300</text></view><view class="anonymous"><view><text>匿名评价</text><text>陪诊员不会看到您的个人信息</text></view><switch checked="{{anonymous}}" color="#007AFF" bindchange="onAnonymous"/></view></view><view wx:if="{{order}}" class="submit-bar"><button loading="{{submitting}}" bindtap="submit">提交评价</button></view></view>
