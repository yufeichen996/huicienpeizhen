@import "/styles/tokens.wxss";.review-page{min-height:100vh;background:var(--color-page)}.content{padding:18rpx var(--page-gutter) calc(140rpx + env(safe-area-inset-bottom))}.summary,.overall,.group,.textarea,.anonymous{border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.summary{padding:24rpx 28rpx}.summary text{display:block}.summary text:first-child{font-size:30rpx;font-weight:700}.summary text:last-child{margin-top:9rpx;color:var(--color-text-secondary);font-size:23rpx}.overall{display:flex;align-items:center;flex-direction:column;margin-top:20rpx;padding:36rpx}.overall>text:first-child{font-size:30rpx;font-weight:700}.stars{display:flex;gap:12rpx;margin-top:24rpx}.stars text{color:#d8d8dd;font-size:58rpx}.stars .active,.star-small.active{color:var(--color-orange)}.score{margin-top:12rpx;color:var(--color-orange);font-weight:700}.group{margin-top:20rpx;padding:8rpx 26rpx}.rating-row{display:flex;align-items:center;justify-content:space-between;min-height:88rpx;border-bottom:1rpx solid var(--color-divider)}.rating-row:last-child{border:0}.star-small{padding:5rpx;color:#d8d8dd;font-size:32rpx}.section-title{display:block;margin:32rpx 4rpx 15rpx;font-size:29rpx;font-weight:700}.tags{display:flex;flex-wrap:wrap;gap:14rpx}.tags text{padding:18rpx 24rpx;border:2rpx solid transparent;border-radius:99rpx;background:#fff;color:var(--color-text-secondary);font-size:24rpx}.tags .active{border-color:var(--color-primary);background:var(--color-primary-soft);color:var(--color-primary)}.textarea{padding:22rpx;color:var(--color-text-tertiary);font-size:21rpx;text-align:right}.textarea textarea{width:100%;min-height:170rpx;font-size:26rpx;text-align:left}.anonymous{display:flex;align-items:center;justify-content:space-between;margin-top:22rpx;padding:24rpx 28rpx}.anonymous text{display:block}.anonymous text:last-child{margin-top:7rpx;color:var(--color-text-tertiary);font-size:21rpx}.submit-bar{position:fixed;z-index:20;right:0;bottom:0;left:0;padding:20rpx var(--page-gutter) calc(20rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.96)}.submit-bar button{height:var(--button-height);border-radius:var(--radius-button);background:var(--color-primary);color:#fff;font-size:29rpx;font-weight:700}
