<view class="catalog-page"><custom-navbar eyebrow="汇慈恩陪诊" title="全局搜索"/><view class="catalog-content"><search-bar value="{{query}}" focus placeholder="搜索医院、科室、服务或陪诊员" bindinput="input" bindconfirm="confirm" bindclear="clear"/><view wx:if="{{!searched && !query}}" class="discovery"><search-history items="{{history}}" bindselect="selectWord" bindremove="removeHistory" bindclear="clearHistory"/><view class="section-title"><text>热门搜索</text></view><view class="hot-chips"><text wx:for="{{hot}}" wx:key="*this" data-value="{{item}}" bindtap="selectWord">{{item}}</text></view><view class="section-title"><text>热门医院</text><text data-type="hospitals" bindtap="all">查看全部</text></view><view class="quick-list"><view wx:for="{{hotHospitals}}" wx:key="id" data-type="hospital" data-id="{{item.id}}" bindtap="open"><text>{{item.icon}}</text><text>{{item.shortName}}</text></view></view><view class="section-title"><text>热门服务</text><text data-type="services" bindtap="all">查看全部</text></view><view class="quick-list"><view wx:for="{{hotServices}}" wx:key="id" data-type="service" data-id="{{item.id}}" bindtap="open"><text>{{item.icon}}</text><text>{{item.name}} · ¥{{item.priceText}}起</text></view></view></view><view wx:if="{{loading}}" class="loading">正在搜索…</view><empty-state wx:elif="{{error}}" title="搜索失败" description="请稍后重试" button-text="重新搜索" bindaction="confirm"/><view wx:elif="{{searched && result.total}}" class="results"><view wx:if="{{result.services.length}}"><view class="section-title"><text>服务</text><text data-type="services" bindtap="all">查看全部</text></view><view class="result-row" wx:for="{{preview.services}}" wx:key="id" data-type="service" data-id="{{item.id}}" bindtap="open"><text class="result-icon">{{item.icon}}</text><view><text>{{item.name}}</text><text>{{item.shortDescription}}</text></view></view></view><view wx:if="{{result.hospitals.length}}"><view class="section-title"><text>医院</text><text data-type="hospitals" bindtap="all">查看全部</text></view><view class="result-row" wx:for="{{preview.hospitals}}" wx:key="id" data-type="hospital" data-id="{{item.id}}" bindtap="open"><text class="result-icon">{{item.icon}}</text><view><text>{{item.name}}</text><text>{{item.level}} · {{item.district}}</text></view></view></view><view wx:if="{{result.departments.length}}"><view class="section-title"><text>科室</text><text data-type="departments" bindtap="all">查看全部</text></view><view class="result-row" wx:for="{{preview.departments}}" wx:key="id" data-type="department" data-hospital-id="{{item.hospitalId}}" data-name="{{item.name}}" bindtap="open"><text class="result-icon">科</text><view><text>{{item.name}}</text><text>{{item.hospitalName}} · {{item.groupName}}</text></view></view></view><view wx:if="{{result.companions.length}}"><view class="section-title"><text>陪诊员</text><text data-type="companions" bindtap="all">查看全部</text></view><view class="result-row" wx:for="{{preview.companions}}" wx:key="id" data-type="companion" data-id="{{item.id}}" bindtap="open"><image src="{{item.avatar}}" lazy-load/><view><text>{{item.name}} · ★{{item.rating}}</text><text>{{item.tags[0]}} · ¥{{item.priceFrom}}起</text></view></view></view></view><empty-state wx:elif="{{searched && !loading}}" title="未找到相关内容" description="换个关键词试试，或联系平台客服获取帮助"/></view></view>
