@import "../catalog/shared.wxss";.discovery{margin-top:28rpx}.hot-chips{display:flex;flex-wrap:wrap;gap:12rpx}.hot-chips text{padding:15rpx 20rpx;border-radius:99rpx;background:#fff;font-size:23rpx}.quick-list{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.quick-list view{display:flex;align-items:center;gap:14rpx;padding:20rpx;border-radius:20rpx;background:#fff}.quick-list view>text:first-child{display:flex;align-items:center;justify-content:center;width:48rpx;height:48rpx;border-radius:14rpx;background:var(--color-primary-soft);color:var(--color-primary);font-weight:700}.result-row{display:flex;align-items:center;gap:18rpx;margin-bottom:12rpx;padding:20rpx;border-radius:20rpx;background:#fff}.result-row image,.result-icon{display:flex;align-items:center;justify-content:center;width:64rpx;height:64rpx;border-radius:18rpx;background:var(--color-primary-soft);color:var(--color-primary);font-weight:700}.result-row image{border-radius:50%}.result-row view{flex:1}.result-row view text{display:block}.result-row view text:first-child{font-weight:700}.result-row view text:last-child{margin-top:7rpx;color:var(--color-text-secondary);font-size:22rpx}
