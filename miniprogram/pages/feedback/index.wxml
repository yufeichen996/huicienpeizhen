<view class="page with-action"><custom-navbar eyebrow="服务支持" title="意见反馈"/><view class="page-content"><view class="group"><view class="field"><text>反馈类型</text><picker range="{{types}}" value="{{typeIndex}}" bindchange="type"><view class="value">{{types[typeIndex]}}</view></picker></view></view><text class="section-title">反馈内容</text><view class="feedback-box"><textarea maxlength="500" value="{{content}}" placeholder="请描述遇到的问题或建议" bindinput="content"/><text>{{content.length}}/500</text></view><button class="upload" bindtap="upload">添加图片（最多 3 张）</button><view class="group"><view class="field"><text>联系方式</text><input value="{{contact}}" placeholder="手机号或微信号（选填）" bindinput="contact"/></view><view class="field"><text>匿名提交</text><switch checked="{{anonymous}}" color="#007AFF" bindchange="anonymous"/></view></view></view><view class="fixed-action"><button class="primary" loading="{{submitting}}" bindtap="submit">提交反馈</button></view></view>
