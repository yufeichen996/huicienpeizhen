@import "../catalog/shared.wxss";.hospital-hero{display:flex;align-items:flex-start;gap:18rpx;padding:26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.hospital-hero>.icon{display:flex;align-items:center;justify-content:center;width:82rpx;height:82rpx;border-radius:23rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:29rpx;font-weight:750}.hospital-hero>view:nth-child(2){flex:1}.hospital-hero>view:nth-child(2) text{display:block;margin-top:7rpx;color:var(--color-text-secondary);font-size:22rpx}.hospital-hero>view:nth-child(2) text:first-child{margin-top:0;color:var(--color-text-primary);font-size:31rpx;font-weight:750}.hospital-hero>view:nth-child(2) text:last-child{display:inline-block;padding:5rpx 10rpx;border-radius:99rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:18rpx}.intro{padding:26rpx;color:var(--color-text-secondary);font-size:24rpx;line-height:1.75}.departments>view{margin-bottom:16rpx;padding:22rpx;border-radius:22rpx;background:#fff}.group-name{display:block;margin-bottom:14rpx;font-weight:700}.departments>view>view{display:flex;flex-wrap:wrap;gap:10rpx}.departments>view>view text{padding:13rpx 17rpx;border-radius:99rpx;background:var(--color-page);color:var(--color-text-secondary);font-size:21rpx}.departments>view>view .selected{background:var(--color-primary);color:#fff}.service-row,.companion-row{display:flex;gap:14rpx}.service-row view,.companion-row view{display:flex;flex:0 0 220rpx;align-items:center;flex-direction:column;gap:8rpx;padding:20rpx;border-radius:20rpx;background:#fff;text-align:center}.service-row view>text:first-child{display:flex;align-items:center;justify-content:center;width:56rpx;height:56rpx;border-radius:17rpx;background:var(--color-primary-soft);color:var(--color-primary);font-weight:700}.service-row view>text:last-child,.companion-row view>text:last-child{color:var(--color-primary);font-size:21rpx}.companion-row image{width:72rpx;height:72rpx;border-radius:50%}.tips text{display:block;padding:17rpx 0;border-bottom:1rpx solid var(--color-divider);font-size:23rpx}.tips text:before{content:'✓';margin-right:12rpx;color:var(--color-green)}.single button:first-child{width:100%;background:var(--color-primary);color:#fff}
