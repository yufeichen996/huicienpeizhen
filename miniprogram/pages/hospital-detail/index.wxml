<view class="catalog-page with-action"><custom-navbar eyebrow="医院详情" title="{{hospital ? hospital.shortName : '常见就诊医院'}}"/><view wx:if="{{hospital}}" class="catalog-content"><view class="hospital-hero"><view class="icon">{{hospital.icon}}</view><view><text>{{hospital.name}}</text><text>{{hospital.level}} · {{hospital.district}}</text><text>{{hospital.address}}</text><text>陪诊服务地点</text></view><favorite-button favorited="{{favorited}}" label bindtoggle="favorite"/></view><view class="section-title"><text>医院简介</text></view><view class="group-card intro">{{hospital.introduction}}</view><view class="section-title"><text>热门科室</text><text>点击后带入预约</text></view><view class="departments"><view wx:for="{{hospital.departmentGroups}}" wx:key="name"><text class="group-name">{{item.name}}</text><view><text class="{{selectedDepartment === department ? 'selected' : ''}}" wx:for="{{item.departments}}" wx:for-item="department" wx:key="*this" data-name="{{department}}" bindtap="department">{{department}}</text></view></view></view><view class="section-title"><text>支持服务</text></view><scroll-view scroll-x show-scrollbar="false"><view class="service-row"><view wx:for="{{services}}" wx:key="id" data-id="{{item.id}}" bindtap="service"><text>{{item.icon}}</text><text>{{item.name}}</text><text>¥{{item.priceText}}起</text></view></view></scroll-view><view class="section-title"><text>推荐陪诊员</text></view><scroll-view scroll-x show-scrollbar="false"><view class="companion-row"><view wx:for="{{companions}}" wx:key="id" data-id="{{item.id}}" bindtap="companion"><image src="{{item.avatar}}" lazy-load/><text>{{item.name}} · ★{{item.rating}}</text><text>¥{{item.priceText}}起</text></view></view></scroll-view><view class="section-title"><text>就医提示</text></view><view class="group-card tips"><text>提前准备有效证件和医院预约凭证</text><text>携带历史病历、检查报告和医保卡</text><text>出发前再次确认院区、科室和就诊时间</text></view></view><view wx:if="{{missing}}" class="loading">未找到该医院</view><view wx:if="{{hospital}}" class="fixed-actions single"><button bindtap="book">选择该医院预约</button></view><login-sheet visible="{{loginVisible}}" bindclose="closeLogin" bindsuccess="loginSuccess"/></view>
