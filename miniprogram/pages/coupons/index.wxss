@import "../profile/shared.wxss";.coupon-list{margin-top:20rpx}.coupon{display:flex;align-items:center;margin-bottom:18rpx;padding:24rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.amount{width:190rpx;border-right:1rpx dashed var(--color-divider);color:var(--color-primary)}.amount text{display:block}.amount text:nth-child(1){display:inline;font-size:25rpx}.amount text:nth-child(2){display:inline;font-size:48rpx;font-weight:750}.amount text:last-child{margin-top:8rpx;color:var(--color-text-secondary);font-size:19rpx}.coupon-copy{flex:1;padding-left:22rpx}.coupon-copy text{display:block}.coupon-copy text:first-child{font-weight:700}.coupon-copy text:nth-child(2){margin-top:9rpx;color:var(--color-text-secondary);font-size:20rpx}.coupon-copy text:last-child{margin-top:8rpx;color:var(--color-primary);font-size:20rpx}.coupon button{padding:16rpx;border-radius:16rpx;background:var(--color-primary);color:#fff;font-size:21rpx}.used,.expired{opacity:.55}
