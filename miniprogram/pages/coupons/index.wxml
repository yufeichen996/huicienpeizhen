<view class="page"><custom-navbar eyebrow="个人中心" title="优惠券"/><view class="page-content"><view class="segmented"><text class="{{active === item.id ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="id" data-id="{{item.id}}" bindtap="tab">{{item.text}}</text></view><view wx:if="{{coupons.length}}" class="coupon-list"><view class="coupon {{item.status}}" wx:for="{{coupons}}" wx:key="id"><view class="amount"><text>¥</text><text>{{item.amountText}}</text><text>满 ¥{{item.thresholdText}} 可用</text></view><view class="coupon-copy"><text>{{item.serviceName}}</text><text>有效期至 {{item.validUntil}}</text><text>{{item.statusText}}</text></view><button wx:if="{{item.status === 'available'}}" data-id="{{item.id}}" bindtap="use">去使用</button></view></view><empty-state wx:else title="暂无优惠券" description="当前分类下没有优惠券"/></view></view>
