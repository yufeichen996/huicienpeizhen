@import "/styles/tokens.wxss";
.book-page { background: var(--color-page); }
.book-content { padding: 12rpx var(--page-gutter) 42rpx; }
.intro { padding: 20rpx 4rpx 28rpx; }
.intro-title, .intro-note { display: block; }
.intro-title { font-size: 44rpx; font-weight: 750; }
.intro-note { margin-top: 12rpx; color: var(--color-text-secondary); font-size: 26rpx; }
.draft-card, .steps-card, .hospital-list { border-radius: var(--radius-card); background: #fff; box-shadow: var(--shadow-card); }
.draft-card { display: flex; align-items: center; justify-content: space-between; padding: 26rpx 28rpx; border: 2rpx solid var(--color-primary-soft); }
.draft-kicker, .draft-summary { display: block; }
.draft-kicker { color: var(--color-primary); font-weight: 700; }
.draft-summary { max-width: 430rpx; margin-top: 8rpx; color: var(--color-text-secondary); font-size: 24rpx; }
.draft-link { display: inline-flex; align-items: center; gap: 2rpx; color: var(--color-primary); font-size: 25rpx; }
.steps-card { display: grid; grid-template-columns: 1fr 1fr; gap: 2rpx; margin-top: 22rpx; padding: 18rpx; }
.step { display: flex; gap: 18rpx; padding: 22rpx 14rpx; }
.step-no { color: var(--color-primary); font-size: 26rpx; font-weight: 750; }
.step-name, .step-note { display: block; }
.step-name { font-weight: 650; }
.step-note { margin-top: 7rpx; color: var(--color-text-tertiary); font-size: 21rpx; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; margin: 40rpx 4rpx 18rpx; font-size: 32rpx; font-weight: 700; }
.section-tip { color: var(--color-text-tertiary); font-size: 22rpx; font-weight: 400; }
.service-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.service-card { padding: 24rpx; border-radius: 22rpx; background: #fff; box-shadow: var(--shadow-card); }
.service-icon { display: flex; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; }
.service-name, .service-price { display: block; margin-top: 16rpx; }
.service-name { font-weight: 700; }.service-price { color: var(--color-primary); font-size: 24rpx; }
.hospital-row { display: flex; align-items: center; min-height: 102rpx; padding: 0 26rpx; border-bottom: 1rpx solid var(--color-divider); }
.hospital-row:last-child { border-bottom: 0; }.hospital-icon { display: flex; align-items: center; justify-content: center; width: 60rpx; height: 60rpx; margin-right: 20rpx; border-radius: 18rpx; background: var(--color-primary-soft); }.hospital-name { flex: 1; font-weight: 600; }.arrow { width: 28rpx; height: 28rpx; display: flex; align-items: center; justify-content: center; flex: none; }
.start-button { height: var(--button-height); margin-top: 36rpx; border-radius: var(--radius-button); background: var(--color-primary); color: #fff; font-size: 30rpx; font-weight: 700; }
.restart-button { height: 70rpx; color: var(--color-text-secondary); font-size: 26rpx; }
