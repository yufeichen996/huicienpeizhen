<view class="catalog-page"><custom-navbar eyebrow="服务目录" title="陪诊服务"/><view class="catalog-content"><view class="filter-row"><scroll-view scroll-x show-scrollbar="false"><text class="filter-chip {{category === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" data-id="{{item.id}}" bindtap="category">{{item.text}}</text></scroll-view></view><picker range="{{sorts}}" range-key="text" bindchange="sort"><view class="sort-control">排序：{{sort === 'recommended' ? '推荐' : sort === 'price' ? '价格从低到高' : '服务时长'}} ›</view></picker><view wx:if="{{loading}}" class="loading">正在加载服务…</view><empty-state wx:elif="{{error}}" title="服务加载失败" description="请稍后重试" button-text="重新加载" bindaction="retry"/><view wx:elif="{{services.length}}"><service-card wx:for="{{services}}" wx:key="id" service="{{item}}" binddetail="detail" bindbook="book" bindfavorite="favorite"/><view wx:if="{{hasMore}}" class="loading">继续上滑加载更多</view></view><empty-state wx:else title="暂无符合条件的服务" description="换个分类试试"/></view><login-sheet visible="{{loginVisible}}" bindclose="closeLogin" bindsuccess="loginSuccess"/></view>
