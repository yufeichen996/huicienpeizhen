<view class="page with-action"><custom-navbar eyebrow="就诊人资料" title="{{title}}"/><view class="page-content"><text class="section-title">基本信息</text><view class="group"><view class="field"><text>姓名 *</text><input value="{{form.name}}" maxlength="20" placeholder="请输入姓名" data-field="name" bindinput="input"/></view><view class="field"><text>性别 *</text><view class="mini-segment"><text class="{{form.gender === 'male' ? 'active' : ''}}" data-value="male" bindtap="gender">男</text><text class="{{form.gender === 'female' ? 'active' : ''}}" data-value="female" bindtap="gender">女</text></view></view><view class="field"><text>出生日期 *</text><picker mode="date" end="{{today}}" value="{{form.birthday}}" bindchange="birthday"><view class="value">{{form.birthday || '请选择'}}</view></picker></view><view class="field"><text>联系电话 *</text><input type="number" maxlength="11" value="{{form.phone}}" placeholder="请输入手机号" data-field="phone" bindinput="input"/></view><view class="field"><text>与本人关系 *</text><picker range="{{relationships}}" range-key="text" value="{{relationshipIndex}}" bindchange="relationship"><view class="value">{{relationships[relationshipIndex].text}}</view></picker></view></view>
<button class="more-button" bindtap="toggleMore">{{more ? '收起健康信息' : '更多健康信息'}} ›</button><view wx:if="{{more}}"><view class="group"><view class="field"><text>身份证号</text><input maxlength="18" value="{{form.idCard}}" placeholder="选填" data-field="idCard" bindinput="input"/></view><view class="field"><text>行动能力</text><view class="mobility"><text class="{{form.mobilityStatus === 'normal' ? 'active' : ''}}" data-value="normal" bindtap="mobility">正常</text><text class="{{form.mobilityStatus === 'limited' ? 'active' : ''}}" data-value="limited" bindtap="mobility">受限</text><text class="{{form.mobilityStatus === 'wheelchair' ? 'active' : ''}}" data-value="wheelchair" bindtap="mobility">轮椅</text></view></view><view class="field"><text>医保类型</text><input value="{{form.medicalInsurance}}" placeholder="选填" data-field="medicalInsurance" bindinput="input"/></view><view class="field"><text>过敏史</text><input value="{{form.allergyHistory}}" placeholder="选填" data-field="allergyHistory" bindinput="input"/></view><view class="field"><text>紧急联系人</text><input value="{{form.emergencyContact}}" placeholder="选填" data-field="emergencyContact" bindinput="input"/></view><view class="field"><text>紧急联系电话</text><input type="number" maxlength="11" value="{{form.emergencyPhone}}" placeholder="选填" data-field="emergencyPhone" bindinput="input"/></view></view><text class="section-title">备注</text><view class="remark"><textarea maxlength="200" value="{{form.remark}}" placeholder="其他需要说明的健康信息" data-field="remark" bindinput="input"/><text>{{remarkLength}}/200</text></view></view><view class="default-row"><view><text>设为默认就诊人</text><text>预约时将优先选择</text></view><switch checked="{{form.isDefault}}" color="#007AFF" bindchange="defaultChange"/></view></view><view class="fixed-action"><button class="primary" loading="{{saving}}" bindtap="save">保存就诊人</button></view></view>
