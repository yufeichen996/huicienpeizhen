@import "../profile/shared.wxss";.mini-segment,.mobility{display:flex;flex:1;justify-content:flex-end;gap:8rpx}.mini-segment text,.mobility text{padding:13rpx 20rpx;border-radius:14rpx;background:var(--color-page);color:var(--color-text-secondary);font-size:23rpx}.mini-segment .active,.mobility .active{background:var(--color-primary-soft);color:var(--color-primary);font-weight:700}.more-button{height:76rpx;margin:20rpx 0;border-radius:20rpx;background:#fff;color:var(--color-primary);font-size:25rpx}.remark{padding:22rpx;border-radius:var(--radius-card);background:#fff;color:var(--color-text-tertiary);font-size:21rpx;text-align:right}.remark textarea{width:100%;min-height:140rpx;text-align:left}.default-row{display:flex;align-items:center;justify-content:space-between;margin-top:22rpx;padding:24rpx 26rpx;border-radius:var(--radius-card);background:#fff}.default-row text{display:block}.default-row text:last-child{margin-top:6rpx;color:var(--color-text-tertiary);font-size:21rpx}
