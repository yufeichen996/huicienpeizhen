<view class="success-page"><custom-navbar eyebrow="汇慈恩陪诊" title="预约结果" /><view wx:if="{{order}}" class="success-content"><view class="success-icon">✓</view><text class="success-title">预约提交成功</text><text class="success-status">{{statusText}}</text>
<view class="order-card"><view><text>订单编号</text><text>{{order.orderNo}}</text></view><view><text>预约服务</text><text>{{order.serviceName}}</text></view><view><text>就诊医院</text><text>{{order.hospitalName}}</text></view><view><text>就诊时间</text><text>{{order.bookingDate}} {{order.bookingTime}}</text></view><view class="amount"><text>订单金额</text><text>¥{{amountText}}</text></view></view>
<view class="notification-card"><view><text>微信服务通知</text><text>接收陪诊师匹配、服务时间和订单进度提醒</text></view><button disabled="{{notificationBusy}}" bindtap="enableNotifications">{{notificationBusy ? '处理中…' : notificationText}}</button></view>
<view class="warm-note">陪诊员确认或匹配成功后，我们会第一时间通知你。请保持手机畅通。</view><button class="primary" bindtap="toOrders">查看订单</button><button class="secondary" bindtap="newBooking">再预约一单</button><button class="home-link" bindtap="toHome">返回首页</button></view></view>
