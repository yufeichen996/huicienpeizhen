@import "/styles/tokens.wxss";
.success-page { min-height:100vh; background:var(--color-page); }.success-content { padding:40rpx var(--page-gutter) calc(50rpx + env(safe-area-inset-bottom)); text-align:center; }.success-icon { display:flex; align-items:center; justify-content:center; width:116rpx; height:116rpx; margin:20rpx auto 26rpx; border-radius:50%; background:var(--color-green); color:#fff; font-size:58rpx; font-weight:700; box-shadow:0 12rpx 30rpx rgba(52,199,89,.22); }.success-title,.success-status { display:block; }.success-title { font-size:42rpx; font-weight:750; }.success-status { margin-top:10rpx; color:var(--color-primary); font-size:25rpx; }.order-card { margin-top:38rpx; padding:16rpx 28rpx; border-radius:var(--radius-card); background:#fff; box-shadow:var(--shadow-card); text-align:left; }.order-card view { display:flex; justify-content:space-between; padding:20rpx 0; border-bottom:1rpx solid var(--color-divider); color:var(--color-text-secondary); font-size:25rpx; }.order-card view text:last-child { max-width:440rpx; color:var(--color-text-primary); text-align:right; }.order-card .amount { border:0; font-weight:700; }.order-card .amount text:last-child { color:var(--color-primary); font-size:32rpx; }.warm-note { margin:24rpx 0 34rpx; padding:22rpx; border-radius:18rpx; background:var(--color-primary-soft); color:#386a9d; font-size:23rpx; line-height:1.6; text-align:left; }.primary,.secondary { height:var(--button-height); margin-top:16rpx; border-radius:var(--radius-button); font-size:29rpx; font-weight:700; }.primary { background:var(--color-primary); color:#fff; }.secondary { background:#fff; color:var(--color-primary); }.home-link { height:70rpx; color:var(--color-text-secondary); font-size:25rpx; }
.notification-card { margin-top:24rpx; padding:24rpx 26rpx; display:flex; align-items:center; gap:20rpx; border-radius:22rpx; background:#fff; box-shadow:var(--shadow-card); text-align:left; }.notification-card>view{min-width:0;flex:1}.notification-card text{display:block}.notification-card text:first-child{font-size:26rpx;font-weight:700}.notification-card text:last-child{margin-top:7rpx;color:var(--color-text-secondary);font-size:21rpx;line-height:32rpx}.notification-card button{width:196rpx;min-height:68rpx;padding:10rpx 16rpx;border-radius:20rpx;color:var(--color-primary);background:var(--color-primary-soft);font-size:21rpx;font-weight:700}.notification-card button[disabled]{opacity:.55}
