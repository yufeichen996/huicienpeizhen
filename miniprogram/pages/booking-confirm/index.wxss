@import "../booking/shared.wxss";
.group-head { display:flex; justify-content:space-between; color:var(--color-text-secondary); font-size:24rpx; }.group-head text:last-child { color:var(--color-primary); }.main-value,.sub-value { display:block; }.main-value { margin-top:14rpx; font-weight:700; }.sub-value { margin-top:8rpx; color:var(--color-text-secondary); font-size:24rpx; }.divider { height:1rpx; margin:24rpx 0; background:var(--color-divider); }.patient-field { display:flex; align-items:center; justify-content:space-between; min-height:120rpx; }.arrow { color:var(--color-text-tertiary); font-size:42rpx; }.need-grid { display:flex; flex-wrap:wrap; gap:14rpx; }.need { padding:18rpx 24rpx; border:2rpx solid transparent; border-radius:99rpx; background:#fff; color:var(--color-text-secondary); font-size:24rpx; }.need.active { border-color:var(--color-primary); background:var(--color-primary-soft); color:var(--color-primary); }.remark-card { padding:22rpx; border-radius:var(--radius-card); background:#fff; text-align:right; color:var(--color-text-tertiary); font-size:21rpx; }.remark-card textarea { width:100%; min-height:150rpx; text-align:left; font-size:27rpx; }.fees view { display:flex; justify-content:space-between; padding:14rpx 0; color:var(--color-text-secondary); }.fees .discount { color:var(--color-green); }.fees .total-row { margin-top:10rpx; padding-top:24rpx; border-top:1rpx solid var(--color-divider); color:var(--color-text-primary); font-size:30rpx; font-weight:700; }.total-row text:last-child { color:var(--color-primary); font-size:36rpx; }.notice { margin-top:24rpx; padding:24rpx; border-radius:20rpx; background:var(--color-orange-soft); color:#8a5a00; font-size:23rpx; line-height:1.6; }.notice text { display:block; }.notice text:first-child { margin-bottom:5rpx; font-weight:700; }.agreement { display:flex; align-items:center; gap:14rpx; padding:28rpx 4rpx; color:var(--color-text-secondary); font-size:23rpx; }.agree-box { display:flex; align-items:center; justify-content:center; width:36rpx; height:36rpx; border:2rpx solid #c7c7cc; border-radius:8rpx; }.agree-box.active { border-color:var(--color-primary); background:var(--color-primary); color:#fff; }.patient-option { display:flex; align-items:center; justify-content:space-between; min-height:110rpx; border-bottom:1rpx solid var(--color-divider); }.patient-option.active { color:var(--color-primary); }.patient-name,.patient-meta { display:block; }.patient-name { font-weight:700; }.patient-meta { margin-top:8rpx; color:var(--color-text-secondary); font-size:23rpx; }.default-tag { padding:4rpx 10rpx; border-radius:99rpx; background:var(--color-primary-soft); color:var(--color-primary); font-size:19rpx; }
