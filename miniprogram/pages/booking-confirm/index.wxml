<view class="booking-page"><custom-navbar eyebrow="陪诊预约" title="确认订单" /><booking-stepper current="4" /><view class="booking-content">
<text class="section-title">预约信息</text><view class="card info-card"><view class="group-head"><text>服务信息</text><text bindtap="modifyService">修改</text></view><text class="main-value">{{draft.serviceName}}</text><text class="sub-value">预计服务 {{draft.duration}} 分钟</text><view class="divider"></view><view class="group-head"><text>就诊信息</text><text bindtap="modifyTime">修改</text></view><text class="main-value">{{draft.hospitalName}} · {{draft.departmentName}}</text><text class="sub-value">{{draft.bookingDateLabel || draft.bookingDate}} {{draft.bookingTime}}</text><view class="divider"></view><view class="group-head"><text>陪诊员</text><text bindtap="modifyCompanion">修改</text></view><text class="main-value">{{draft.companionMode === 'platform' ? '平台智能匹配' : draft.companionName}}</text></view>
<text class="section-title">就诊人</text><view class="card patient-field" bindtap="openPatients"><view wx:if="{{draft.patientId}}"><text class="main-value">{{draft.patientName}}</text><text class="sub-value">{{draft.patientPhone}}</text></view><text wx:else class="placeholder">请选择就诊人（必填）</text><text class="arrow">›</text></view>
<text class="section-title">特殊需求</text><view class="need-grid"><text class="need {{item.selected ? 'active' : ''}}" wx:for="{{needOptions}}" wx:key="value" data-value="{{item.value}}" bindtap="toggleNeed">{{item.value}}</text></view>
<text class="section-title">备注</text><view class="remark-card"><textarea maxlength="200" value="{{draft.remark}}" placeholder="如有其他需要，请告诉陪诊员" bindinput="onRemark" /><text>{{remarkLength}}/200</text></view>
<text class="section-title">费用明细</text><view class="card fees"><view><text>服务费</text><text>¥{{serviceFeeText}}</text></view><view><text>指定陪诊员差额</text><text>¥{{companionFeeText}}</text></view><view class="discount"><text>预约优惠</text><text>-¥{{discountText}}</text></view><view class="total-row"><text>合计</text><text>¥{{totalText}}</text></view></view>
<view class="notice"><text>取消说明</text><text>服务开始前 24 小时可免费取消；临近服务时间取消可能产生服务准备费用。</text></view>
<view class="agreement" bindtap="toggleAgreement"><text class="agree-box {{draft.agreementAccepted ? 'active' : ''}}">{{draft.agreementAccepted ? '✓' : ''}}</text><text>我已阅读并同意《汇慈恩陪诊服务协议》</text></view>
</view><booking-action-bar primary-text="确认预约" total-text="{{totalText}}" loading="{{submitting}}" bindprimary="onSubmit" bindsecondary="onBack" />
<view wx:if="{{patientSheet}}" class="sheet-mask" bindtap="closePatients"><view class="sheet" catchtap="stop"><text class="sheet-title">选择就诊人</text><view class="patient-option {{draft.patientId === item.id ? 'active' : ''}}" wx:for="{{patients}}" wx:key="id" data-id="{{item.id}}" bindtap="selectPatient"><view><text class="patient-name">{{item.name}} <text wx:if="{{item.isDefault}}" class="default-tag">默认</text></text><text class="patient-meta">{{item.genderText}} · {{item.age}}岁 · {{item.phoneMasked}}</text></view><text>{{draft.patientId === item.id ? '✓' : ''}}</text></view><button class="add-patient" bindtap="addPatient">＋ 新增就诊人</button></view></view></view>
