.stub-page { background: var(--color-page); }
.stub-content { padding: 44rpx var(--page-gutter); }
.stub-title { display: block; color: var(--color-text-primary); font-size: var(--font-title); line-height: 82rpx; font-weight: 750; }
.stub-desc { display: block; margin: 8rpx 0 34rpx; color: var(--color-text-secondary); font-size: var(--font-body); line-height: 44rpx; }
.stub-button { width: 100%; height: var(--button-height); margin-top: 28rpx; border-radius: var(--radius-button); color: #fff; background: var(--color-primary); font-size: 28rpx; font-weight: 700; }
.empty-state { min-height: 300rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
.empty-icon { color: var(--color-primary); font-size: 58rpx; }
.empty-title { margin-top: 18rpx; color: var(--color-text-primary); font-size: 32rpx; font-weight: 700; }
.empty-desc { margin-top: 10rpx; color: var(--color-text-secondary); font-size: var(--font-caption); line-height: 38rpx; }
