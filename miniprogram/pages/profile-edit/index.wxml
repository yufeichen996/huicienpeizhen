<view class="page with-action"><custom-navbar eyebrow="个人资料" title="编辑资料"/><view class="page-content"><view class="avatar-card"><image src="{{user.avatar}}"/><text>当前为模拟头像，正式上线后接入微信头像选择</text></view><view class="group"><view class="field"><text>昵称</text><input value="{{nickname}}" maxlength="20" placeholder="请输入昵称" bindinput="inputName"/></view><view class="field"><text>手机号</text><text class="value">{{user.phoneMasked}}</text></view><view class="field"><text>所在城市</text><input value="{{city}}" maxlength="20" placeholder="请输入城市" bindinput="inputCity"/></view></view><text class="section-title">性别</text><view class="segmented"><text class="{{gender === 'male' ? 'active' : ''}}" data-value="male" bindtap="gender">男</text><text class="{{gender === 'female' ? 'active' : ''}}" data-value="female" bindtap="gender">女</text><text class="{{gender === 'unknown' ? 'active' : ''}}" data-value="unknown" bindtap="gender">不展示</text></view></view><view class="fixed-action"><button class="primary" loading="{{saving}}" bindtap="save">保存资料</button></view></view>
