@import "../profile/shared.wxss";.address{margin-bottom:18rpx;padding:24rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.head{display:flex;align-items:center;gap:14rpx;font-weight:700}.head text:last-child{padding:4rpx 10rpx;border-radius:99rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:18rpx}.address>text{display:block;margin-top:12rpx;color:var(--color-text-secondary);font-size:23rpx;line-height:1.5}.actions{display:flex;justify-content:flex-end;gap:12rpx;margin-top:18rpx}.actions button,.cancel{padding:15rpx 22rpx;border-radius:16rpx;background:var(--color-page);color:var(--color-primary);font-size:22rpx}.cancel{width:100%;margin-top:20rpx}
