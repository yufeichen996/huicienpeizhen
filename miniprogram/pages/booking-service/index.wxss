@import "../booking/shared.wxss";
.service-card { display: flex; align-items: center; gap: 22rpx; margin-bottom: 18rpx; padding: 26rpx; border: 3rpx solid transparent; border-radius: var(--radius-card); background: #fff; box-shadow: var(--shadow-card); }
.service-card.selected { border-color: var(--color-primary); background: var(--color-primary-soft); }
.service-icon { display: flex; flex: 0 0 76rpx; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; border-radius: 22rpx; background: var(--color-primary-soft); color: var(--color-primary); font-size: 30rpx; font-weight: 750; }
.service-copy { flex: 1; min-width: 0; }.service-name { font-size: 31rpx; font-weight: 700; }.suggested { margin-left: 12rpx; padding: 5rpx 11rpx; border-radius: 99rpx; background: var(--color-orange-soft); color: var(--color-orange); font-size: 19rpx; }.service-desc,.service-duration { display:block; margin-top: 8rpx; color: var(--color-text-secondary); font-size: 23rpx; }.service-duration { color: var(--color-text-tertiary); }.service-right { align-self: stretch; display:flex; flex-direction:column; align-items:flex-end; justify-content:space-between; }.check { width:38rpx; height:38rpx; border-radius:50%; background:var(--color-primary); color:#fff; text-align:center; line-height:38rpx; }.price { color:var(--color-primary); font-size:24rpx; font-weight:650; }
