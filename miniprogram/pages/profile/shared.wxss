@import "/styles/tokens.wxss";.page{min-height:100vh;padding-bottom:calc(44rpx + env(safe-area-inset-bottom));background:var(--color-page)}.page.with-action{padding-bottom:calc(140rpx + env(safe-area-inset-bottom))}.page-content{padding:18rpx var(--page-gutter) 40rpx}.section-title{display:block;margin:32rpx 4rpx 15rpx;font-size:29rpx;font-weight:700}.group{padding:8rpx 26rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.field{display:flex;align-items:center;min-height:92rpx;border-bottom:1rpx solid var(--color-divider)}.field:last-child{border:0}.field>text:first-child{width:180rpx;color:var(--color-text-secondary);font-size:25rpx}.field input,.field picker,.field .value{flex:1;text-align:right;font-size:26rpx}.primary{height:var(--button-height);border-radius:var(--radius-button);background:var(--color-primary);color:#fff;font-size:28rpx;font-weight:700}.fixed-action{position:fixed;z-index:20;right:0;bottom:0;left:0;padding:20rpx var(--page-gutter) calc(20rpx + env(safe-area-inset-bottom));border-top:1rpx solid var(--color-divider);background:rgba(255,255,255,.96)}.segmented{display:flex;padding:7rpx;border-radius:20rpx;background:#e5e5ea}.segmented text{flex:1;padding:18rpx 10rpx;border-radius:15rpx;color:var(--color-text-secondary);font-size:23rpx;text-align:center}.segmented .active{background:#fff;color:var(--color-primary);font-weight:700;box-shadow:0 3rpx 12rpx rgba(0,0,0,.08)}
