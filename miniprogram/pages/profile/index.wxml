<view class="safe-page profile-page"><custom-navbar eyebrow="个人中心" title="我的"/><view class="content"><profile-header user="{{user}}" logged-in="{{loggedIn}}" bindlogin="openLogin" bindedit="edit"/><button wx:if="{{!loggedIn}}" class="login-button" bindtap="openLogin">微信一键登录</button><order-shortcuts items="{{orderShortcuts}}" bindselect="orderSelect"/>
<text class="section-title">常用功能</text><settings-group><settings-row icon="patient" title="就诊人管理" value="{{patientCount}}人" bindtap="patients"/><settings-row icon="favorite" title="我的收藏" value="{{favoriteCount}}" bindtap="favorites"/><settings-row icon="coupon" title="优惠券" value="{{couponCount}}张" bindtap="coupons"/><settings-row icon="address" title="常用地址" last bindtap="addresses"/></settings-group>
<text class="section-title">服务与设置</text><settings-group><settings-row icon="customer-service" title="联系客服" bindtap="customer"/><settings-row icon="notification" variant="outline" title="消息通知" value="订阅设置" bindtap="notifications"/><settings-row icon="feedback" title="意见反馈" bindtap="feedback"/><settings-row icon="agreement" title="服务协议" bindtap="agreement"/><settings-row icon="privacy" title="隐私政策" bindtap="privacy"/><settings-row icon="security" title="账号与安全" bindtap="security"/><settings-row icon="about" title="关于我们" last bindtap="about"/></settings-group>
<button wx:if="{{loggedIn}}" class="logout" bindtap="logout">退出登录</button></view><login-sheet visible="{{loginVisible}}" bindclose="closeLogin" bindsuccess="loginSuccess"/></view>
