<view class="page with-action"><custom-navbar eyebrow="健康档案" title="就诊人管理"/><view class="page-content"><view wx:if="{{patients.length}}"><patient-card wx:for="{{patients}}" wx:key="id" patient="{{item}}" bindedit="edit" binddefault="setDefault" bindremove="remove"/></view><empty-state wx:else title="暂无就诊人" description="添加就诊人后，预约时可以快速选择" button-text="新增就诊人" bindaction="add"/></view><view class="fixed-action"><button class="primary" bindtap="add">新增就诊人</button></view></view>
