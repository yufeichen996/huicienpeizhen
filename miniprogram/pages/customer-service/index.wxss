@import "../profile/shared.wxss";.service-card{padding:28rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.service-card text{display:block}.service-card text:first-child{font-size:31rpx;font-weight:700}.service-card text:nth-child(2){margin-top:9rpx;color:var(--color-text-secondary)}.service-card button{height:76rpx;margin-top:18rpx;border-radius:20rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:24rpx}.service-card .primary{background:var(--color-primary);color:#fff}.faq{padding:22rpx 0;border-bottom:1rpx solid var(--color-divider)}.faq:last-child{border:0}.faq text{display:block}.faq text:first-child{font-weight:700}.faq text:last-child{margin-top:9rpx;color:var(--color-text-secondary);font-size:23rpx;line-height:1.55}.emergency{margin-top:22rpx;padding:22rpx;border-radius:20rpx;background:var(--color-orange-soft);color:#8a5a00;font-size:22rpx;line-height:1.55}
