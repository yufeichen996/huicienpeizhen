<view class="catalog-page"><custom-navbar eyebrow="专业服务人员" title="陪诊员"/><view class="catalog-content"><search-bar value="{{query}}" placeholder="搜索姓名、标签或简介" bindinput="search" bindclear="clear"/><view class="picker-grid"><picker range="{{services}}" range-key="name" value="{{serviceIndex}}" bindchange="service"><view>{{services[serviceIndex].name}} ›</view></picker><picker range="{{hospitals}}" range-key="name" value="{{hospitalIndex}}" bindchange="hospital"><view>{{hospitals[hospitalIndex].name}} ›</view></picker><picker range="{{genders}}" range-key="name" value="{{genderIndex}}" bindchange="gender"><view>{{genders[genderIndex].name}} ›</view></picker><picker range="{{sorts}}" range-key="name" value="{{sortIndex}}" bindchange="sort"><view>{{sorts[sortIndex].name}} ›</view></picker></view><view wx:if="{{loading}}" class="loading">正在加载陪诊员…</view><empty-state wx:elif="{{error}}" title="加载失败" button-text="重新加载" bindaction="retry"/><view wx:elif="{{items.length}}"><view class="companion-card" wx:for="{{items}}" wx:key="id"><view class="head"><image src="{{item.avatar}}" lazy-load data-id="{{item.id}}" bindtap="detail"/><view class="copy" data-id="{{item.id}}" bindtap="detail"><view><text>{{item.name}}</text><text wx:if="{{item.verified}}">实名</text></view><text>★ {{item.rating}} · {{item.serviceCount}} 次 · {{item.responseText}}</text></view><favorite-button favorited="{{item.favorited}}" data-id="{{item.id}}" bindtoggle="favorite"/></view><view class="tags"><text wx:for="{{item.tags}}" wx:key="*this">{{item}}</text></view><text class="hospital">服务医院：{{item.hospitalText}}</text><text class="intro">{{item.bio}}</text><view class="foot"><text><text>¥{{item.priceText}}</text> {{item.priceUnit}}</text><button data-id="{{item.id}}" bindtap="book">立即预约</button></view></view><view wx:if="{{hasMore}}" class="loading">继续上滑加载更多</view></view><empty-state wx:else title="暂无符合条件的陪诊员" description="调整筛选条件试试"/></view><login-sheet visible="{{loginVisible}}" bindclose="closeLogin" bindsuccess="loginSuccess"/></view>
