@import "../catalog/shared.wxss";.picker-grid{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin:16rpx 0}.picker-grid view{padding:17rpx;border-radius:17rpx;background:#fff;color:var(--color-text-secondary);font-size:22rpx;text-align:center}.companion-card{margin-bottom:18rpx;padding:24rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.head{display:flex;align-items:center;gap:18rpx}.head>image{width:88rpx;height:88rpx;border-radius:50%;background:var(--color-primary-soft)}.copy{flex:1}.copy>view{display:flex;align-items:center;gap:10rpx}.copy>view text:first-child{font-size:30rpx;font-weight:750}.copy>view text:last-child{padding:4rpx 9rpx;border-radius:99rpx;background:var(--color-green-soft);color:var(--color-green);font-size:17rpx}.copy>text{display:block;margin-top:9rpx;color:var(--color-text-secondary);font-size:21rpx}.tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:16rpx}.tags text{padding:6rpx 11rpx;border-radius:99rpx;background:var(--color-primary-soft);color:var(--color-primary);font-size:19rpx}.hospital,.intro{display:block;margin-top:13rpx;color:var(--color-text-secondary);font-size:22rpx}.intro{line-height:1.55}.foot{display:flex;align-items:center;justify-content:space-between;margin-top:18rpx;padding-top:18rpx;border-top:1rpx solid var(--color-divider);color:var(--color-text-secondary);font-size:20rpx}.foot>text>text{color:var(--color-primary);font-size:31rpx;font-weight:750}.foot button{padding:17rpx 24rpx;border-radius:18rpx;background:var(--color-primary);color:#fff;font-size:22rpx;font-weight:700}
