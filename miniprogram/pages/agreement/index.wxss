@import "/styles/tokens.wxss";.article-page{min-height:100vh;background:var(--color-page)}.article{padding:20rpx var(--page-gutter) calc(40rpx + env(safe-area-inset-bottom))}.notice{padding:22rpx;border-radius:20rpx;background:var(--color-orange-soft);color:#8a5a00;font-size:22rpx;line-height:1.55}.date{display:block;margin:22rpx 4rpx;color:var(--color-text-tertiary);font-size:21rpx}.section{margin-bottom:18rpx;padding:28rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.section text{display:block}.section text:first-child{font-size:29rpx;font-weight:700}.section text:last-child{margin-top:14rpx;color:var(--color-text-secondary);font-size:25rpx;line-height:1.75}
