<view class="booking-page"><custom-navbar eyebrow="陪诊预约" title="就诊信息" /><booking-stepper current="2" /><view class="booking-content">
<text class="section-title">选择医院与科室</text><view class="card"><view class="field-row" bindtap="openHospitals"><text class="field-label">就诊医院</text><text class="field-value {{hospitalName ? '' : 'placeholder'}}">{{hospitalName || '请选择医院'}} ›</text></view></view>
<view class="chips"><text class="chip {{departmentName === item ? 'active' : ''}}" wx:for="{{departments}}" wx:key="*this" data-value="{{item}}" bindtap="selectDepartment">{{item}}</text></view>
<text class="section-title">选择就诊日期</text><scroll-view class="date-scroll" scroll-x enhanced show-scrollbar="false"><view class="date-row"><view class="date-card {{bookingDate === item.date ? 'active' : ''}} {{item.disabled ? 'disabled' : ''}}" wx:for="{{dates}}" wx:key="date" data-date="{{item.date}}" bindtap="selectDate"><text>{{item.isToday ? '今天' : item.weekday}}</text><text class="date-day">{{item.day}}</text><text wx:if="{{item.disabled}}" class="full">不可约</text></view></view></scroll-view>
<text class="section-title">选择到院时间</text><view class="time-grid"><text class="time {{bookingTime === item.value ? 'active' : ''}} {{item.disabled ? 'disabled' : ''}}" wx:for="{{times}}" wx:key="value" data-value="{{item.value}}" bindtap="selectTime">{{item.value}}{{item.disabled ? ' 已满' : ''}}</text></view>
</view><booking-action-bar disabled="{{!valid}}" bindprimary="onNext" bindsecondary="onBack" />
<view wx:if="{{hospitalSheet}}" class="sheet-mask" bindtap="closeHospitals"><view class="sheet" catchtap="stop"><text class="sheet-title">选择医院</text><scroll-view scroll-y class="hospital-scroll"><view class="hospital-option {{hospitalId === item.id ? 'active' : ''}}" wx:for="{{hospitals}}" wx:key="id" data-id="{{item.id}}" bindtap="selectHospital"><text class="hospital-badge">{{item.icon}}</text><text>{{item.name}}</text><text class="selected-mark">{{hospitalId === item.id ? '✓' : ''}}</text></view></scroll-view></view></view></view>
