@import "../booking/shared.wxss";
.chips { display:grid; grid-template-columns:repeat(4,1fr); gap:14rpx; margin-top:20rpx; }.chip,.time { display:flex; align-items:center; justify-content:center; min-height:68rpx; border:2rpx solid transparent; border-radius:18rpx; background:#fff; color:var(--color-text-secondary); font-size:25rpx; }.chip.active,.time.active { border-color:var(--color-primary); background:var(--color-primary-soft); color:var(--color-primary); font-weight:650; }.date-scroll { width:100%; }.date-row { display:flex; gap:14rpx; padding-bottom:8rpx; }.date-card { flex:0 0 108rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:136rpx; border:2rpx solid transparent; border-radius:20rpx; background:#fff; color:var(--color-text-secondary); font-size:22rpx; }.date-card.active { border-color:var(--color-primary); background:var(--color-primary); color:#fff; }.date-day { margin-top:10rpx; font-size:34rpx; font-weight:700; }.full { margin-top:4rpx; font-size:18rpx; }.disabled { opacity:.42; }.time-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14rpx; }.time { min-height:76rpx; font-size:23rpx; }.hospital-scroll { max-height:56vh; }.hospital-option { display:flex; align-items:center; min-height:102rpx; border-bottom:1rpx solid var(--color-divider); }.hospital-badge { display:flex; align-items:center; justify-content:center; width:58rpx; height:58rpx; margin-right:18rpx; border-radius:17rpx; background:var(--color-primary-soft); color:var(--color-primary); }.hospital-option.active { color:var(--color-primary); font-weight:650; }.selected-mark { margin-left:auto; color:var(--color-primary); }
