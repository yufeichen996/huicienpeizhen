.home-page { overflow-x: hidden; }
.content { display: block; padding: 18rpx var(--page-gutter) 0; }
.welcome-block { width: 100%; margin: 8rpx 0 26rpx; }
.welcome-kicker { display: block; margin-bottom: 8rpx; color: var(--color-primary); font-size: var(--font-caption); line-height: 34rpx; font-weight: 650; }
.welcome-title { display: block; width: 100%; max-width: none; color: var(--color-text-primary); font-size: 54rpx; line-height: 1.2; font-weight: 700; letter-spacing: -1rpx; white-space: nowrap; }
.search-box { width: 100% !important; min-width: 0; height: 88rpx; margin: 0 !important; padding: 0 24rpx !important; display: flex !important; align-items: center; text-align: left; border: 1rpx solid rgba(60, 60, 67, 0.06); border-radius: 24rpx; background: rgba(255, 255, 255, 0.86); box-shadow: var(--shadow-card); line-height: 1; }
.search-icon { width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center; flex: none; }
.search-placeholder { flex: 1; margin-left: 10rpx; color: var(--color-text-tertiary); font-size: var(--font-body); line-height: 40rpx; }
.search-arrow { width: 28rpx; height: 28rpx; display: flex; align-items: center; justify-content: center; flex: none; }
.hero-card { position: relative; height: 360rpx; margin-top: 28rpx; overflow: hidden; border-radius: 32rpx; background: var(--color-primary); box-shadow: 0 18rpx 44rpx rgba(0, 122, 255, 0.2); }
.hero-image { position: absolute; inset: 0; width: 100%; height: 100%; }
.hero-gradient { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0, 90, 220, 0.98) 0%, rgba(0, 122, 255, 0.84) 43%, rgba(0, 122, 255, 0.06) 100%); }
.hero-content { position: relative; z-index: 1; height: 100%; padding: 42rpx; display: flex; flex-direction: column; align-items: flex-start; }
.hero-kicker { color: rgba(255, 255, 255, 0.76); font-size: var(--font-caption); line-height: 34rpx; font-weight: 600; }
.hero-title { margin-top: 10rpx; color: #fff; font-size: 42rpx; line-height: 56rpx; font-weight: 750; }
.hero-button { width: 176rpx !important; min-width: 176rpx; height: 70rpx; margin: auto 0 0 !important; padding: 0 !important; display: flex !important; align-items: center; justify-content: center; border-radius: 22rpx; color: var(--color-primary); background: #fff; font-size: 26rpx; line-height: 1; font-weight: 700; box-shadow: 0 8rpx 20rpx rgba(0, 62, 140, 0.18); }
.section-label { margin: 34rpx 4rpx 18rpx; color: var(--color-text-secondary); font-size: var(--font-caption); line-height: 34rpx; font-weight: 600; }
.feature-grid { width: 100%; display: flex; overflow: hidden; }
.feature-cell { width: 25%; min-width: 0; flex: 0 0 25%; overflow: hidden; }
.quick-entry { width: 100% !important; min-width: 0; min-height: 176rpx; margin: 0 !important; padding: 8rpx 0 !important; display: flex !important; flex-direction: column; align-items: center; justify-content: center; background: transparent; line-height: 1; }
.quick-label { max-width: 100%; margin-top: 14rpx; overflow: hidden; color: var(--color-text-primary); font-size: 24rpx; line-height: 32rpx; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }
.trust-card { margin-top: 24rpx; }
.trust-grid { min-height: 142rpx; display: grid; grid-template-columns: 1fr 1rpx 1fr 1rpx 1fr; align-items: center; }
.trust-item { min-width: 0; display: flex; flex-direction: column; align-items: center; text-align: center; }
.trust-icon { width: 28rpx; height: 28rpx; display: flex; align-items: center; justify-content: center; }
.trust-title { margin-top: 8rpx; color: var(--color-text-primary); font-size: 23rpx; line-height: 30rpx; font-weight: 650; }
.trust-value { margin-top: 2rpx; color: var(--color-text-secondary); font-size: 20rpx; line-height: 28rpx; white-space: nowrap; }
.trust-separator { width: 1rpx; height: 72rpx; background: var(--color-divider); }
.section-heading { margin: 46rpx 4rpx 20rpx; display: flex; align-items: center; justify-content: space-between; }
.section-title { color: var(--color-text-primary); font-size: 34rpx; line-height: 44rpx; font-weight: 750; }
.section-action { width: auto !important; min-width: 0 !important; min-height: 64rpx; margin: 0 0 0 auto !important; padding: 0 !important; flex: 0 0 auto; display: inline-flex !important; align-items: center; justify-content: flex-end; gap: 4rpx; color: var(--color-primary); font-size: 25rpx; }
.companion-list { width: 100%; display: flex; flex-direction: column; gap: 22rpx; }
.hospital-scroll { width: calc(100% + var(--page-gutter)); overflow: visible; }
.hospital-row { padding-right: var(--page-gutter); display: inline-flex; gap: 20rpx; }
.hospital-heading { margin-top: 48rpx; }
.city-badge { padding: 8rpx 16rpx; border-radius: var(--radius-pill); color: var(--color-primary); background: var(--color-primary-soft); font-size: 22rpx; font-weight: 600; }
.hospital-row { padding-bottom: 8rpx; }
.scope-notice { margin-top: 24rpx; padding: 22rpx 24rpx; display: flex; align-items: flex-start; border-radius: 22rpx; background: rgba(0, 122, 255, 0.07); }
.scope-icon { width: 34rpx; height: 34rpx; margin-right: 14rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 50%; color: #fff; background: var(--color-primary); font-size: 22rpx; font-weight: 700; }
.scope-text { flex: 1; color: var(--color-text-secondary); font-size: 23rpx; line-height: 36rpx; }
.sheet-profile { display: flex; flex-direction: column; align-items: center; }
.sheet-avatar { width: 160rpx; height: 160rpx; border-radius: 50%; background: var(--color-primary-soft); }
.sheet-name-row { margin-top: 22rpx; display: flex; align-items: center; gap: 16rpx; }
.sheet-name { color: var(--color-text-primary); font-size: 38rpx; line-height: 48rpx; font-weight: 750; }
.sheet-rating { display: flex; align-items: center; gap: 6rpx; color: var(--color-orange); font-size: 26rpx; font-weight: 700; }
.sheet-meta { margin-top: 6rpx; color: var(--color-text-secondary); font-size: 24rpx; line-height: 34rpx; }
.sheet-tags { margin-top: 20rpx; display: flex; flex-wrap: wrap; justify-content: center; gap: 10rpx; }
.sheet-tag { padding: 9rpx 16rpx; border-radius: var(--radius-pill); color: var(--color-primary); background: var(--color-primary-soft); font-size: 22rpx; }
.sheet-bio { width: 100%; margin-top: 26rpx; padding: 24rpx; border-radius: 22rpx; color: var(--color-text-secondary); background: var(--color-page); font-size: var(--font-body); line-height: 46rpx; }
.sheet-profile-link { width: 100% !important; height: 76rpx; margin: 12rpx 0 0 !important; padding: 0 8rpx !important; display: flex !important; align-items: center; justify-content: center; gap: 8rpx; color: var(--color-primary); background: transparent; font-size: 26rpx; font-weight: 650; }
.sheet-footer { width: 100%; margin-top: 28rpx; display: flex; align-items: center; gap: 24rpx; }
.sheet-price { min-width: 190rpx; display: flex; flex-direction: column; }
.sheet-price-label { color: var(--color-text-secondary); font-size: 22rpx; line-height: 30rpx; }
.sheet-price-currency { color: var(--color-primary); font-size: 24rpx; font-weight: 700; }
.sheet-price-amount { color: var(--color-primary); font-size: 44rpx; line-height: 52rpx; font-weight: 750; }
.sheet-price-unit { color: var(--color-text-secondary); font-size: 22rpx; }
.primary-button { height: var(--button-height); margin: 0 !important; padding: 0 !important; flex: 1; display: flex !important; align-items: center; justify-content: center; border-radius: var(--radius-button); color: #fff; background: var(--color-primary); font-size: 28rpx; line-height: 1; font-weight: 700; box-shadow: 0 12rpx 26rpx rgba(0, 122, 255, 0.22); }
