@import "../booking/shared.wxss";
.segment { display:flex; padding:7rpx; border-radius:22rpx; background:var(--color-divider); }.segment-item { flex:1; padding:20rpx 10rpx; border-radius:17rpx; color:var(--color-text-secondary); text-align:center; font-size:25rpx; }.segment-item.active { background:#fff; color:var(--color-primary); font-weight:700; box-shadow:0 4rpx 14rpx rgba(25,73,120,.07); }.platform-card { margin-top:24rpx; padding:36rpx; border-radius:var(--radius-card); background:var(--color-primary); color:#fff; box-shadow:var(--shadow-card); }.platform-title,.platform-note { display:block; }.platform-title { font-size:34rpx; font-weight:750; }.platform-note { margin-top:16rpx; color:rgba(255,255,255,.86); font-size:25rpx; line-height:1.65; }.guarantees { display:grid; grid-template-columns:1fr 1fr; gap:20rpx; margin-top:32rpx; font-size:24rpx; }.companion-note { margin-top:24rpx; }.companion-card { display:flex; gap:20rpx; margin-bottom:18rpx; padding:24rpx; border:3rpx solid transparent; border-radius:var(--radius-card); background:#fff; box-shadow:var(--shadow-card); }.companion-card.selected { border-color:var(--color-primary); }.avatar { flex:0 0 92rpx; width:92rpx; height:92rpx; border-radius:50%; background:var(--color-primary-soft); }.companion-copy { flex:1; min-width:0; }.companion-name,.companion-meta { display:block; }.companion-name { font-size:30rpx; font-weight:700; }.rating { color:var(--color-orange); font-size:23rpx; }.companion-meta { margin-top:8rpx; color:var(--color-text-secondary); font-size:22rpx; }.tags { display:flex; flex-wrap:wrap; gap:8rpx; margin-top:12rpx; }.tags text { padding:5rpx 11rpx; border-radius:99rpx; background:var(--color-primary-soft); color:var(--color-primary); font-size:19rpx; }.detail-link { margin-top:14rpx; color:var(--color-primary); font-size:23rpx; text-align:left; }.companion-price { display:flex; flex-direction:column; align-items:flex-end; justify-content:space-between; color:var(--color-primary); font-size:23rpx; font-weight:650; }.check { width:38rpx; height:38rpx; border-radius:50%; background:var(--color-primary); color:#fff; text-align:center; line-height:38rpx; }.detail-sheet { text-align:center; }.detail-avatar { width:132rpx; height:132rpx; border-radius:50%; background:var(--color-primary-soft); }.detail-rating { color:var(--color-orange); }.detail-bio { display:block; margin-top:24rpx; color:var(--color-text-secondary); line-height:1.7; text-align:left; }.detail-select { height:84rpx; margin-top:30rpx; border-radius:22rpx; background:var(--color-primary); color:#fff; font-weight:700; }
