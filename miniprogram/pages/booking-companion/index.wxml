<view class="booking-page"><custom-navbar eyebrow="陪诊预约" title="选择陪诊员" /><booking-stepper current="3" /><view class="booking-content">
<text class="section-title">陪诊员安排方式</text><view class="segment"><text class="segment-item {{mode === 'platform' ? 'active' : ''}}" data-mode="platform" bindtap="selectMode">平台智能匹配</text><text class="segment-item {{mode === 'selected' ? 'active' : ''}}" data-mode="selected" bindtap="selectMode">指定陪诊员</text></view>
<view wx:if="{{mode === 'platform'}}" class="platform-card"><text class="platform-title">交给平台，省心更快速</text><text class="platform-note">系统会根据医院、时段和服务经验，为你匹配合适的陪诊员。</text><view class="guarantees"><text>✓ 响应更快速</text><text>✓ 全员实名认证</text><text>✓ 平台服务保障</text><text>✓ 不收指定服务费</text></view></view>
<view wx:else><text class="section-note companion-note">点击卡片选择，点击“查看资料”了解更多</text><view class="companion-card {{selectedId === item.id ? 'selected' : ''}}" wx:for="{{companions}}" wx:key="id" data-id="{{item.id}}" bindtap="selectCompanion"><image class="avatar" src="{{item.avatar}}" mode="aspectFill" /><view class="companion-copy"><text class="companion-name">{{item.name}} <text class="rating">★ {{item.rating}}</text></text><text class="companion-meta">{{item.serviceCount}} 次服务 · 响应 {{item.responseTime}}</text><view class="tags"><text wx:for="{{item.tags}}" wx:key="*this">{{item}}</text></view><button class="detail-link" data-id="{{item.id}}" catchtap="openDetail">查看资料</button></view><view class="companion-price"><text class="check">{{selectedId === item.id ? '✓' : ''}}</text><text>¥{{item.priceFrom}}起</text></view></view></view>
</view><booking-action-bar disabled="{{mode === 'selected' && !selectedId}}" bindprimary="onNext" bindsecondary="onBack" />
<view wx:if="{{detail}}" class="sheet-mask" bindtap="closeDetail"><view class="sheet detail-sheet" catchtap="stop"><image class="detail-avatar" src="{{detail.avatar}}" /><text class="sheet-title">{{detail.name}}</text><text class="detail-rating">★ {{detail.rating}} · {{detail.serviceCount}} 次服务</text><text class="detail-bio">{{detail.bio}}</text><button class="detail-select" data-id="{{detail.id}}" bindtap="selectCompanion">选择这位陪诊员</button></view></view></view>
