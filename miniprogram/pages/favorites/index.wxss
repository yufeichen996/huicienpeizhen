@import "../profile/shared.wxss";.favorite-list{margin-top:20rpx}.favorite-card{display:flex;align-items:center;gap:20rpx;margin-bottom:18rpx;padding:24rpx;border-radius:var(--radius-card);background:#fff;box-shadow:var(--shadow-card)}.favorite-card image{width:82rpx;height:82rpx;border-radius:50%;background:var(--color-primary-soft)}.favorite-card view{flex:1}.favorite-card text{display:block}.favorite-card text:first-child{font-weight:700}.favorite-card text:last-child{margin-top:8rpx;color:var(--color-text-secondary);font-size:22rpx}.favorite-card button{padding:15rpx;border-radius:16rpx;background:#fff0ef;color:var(--color-error);font-size:21rpx}
