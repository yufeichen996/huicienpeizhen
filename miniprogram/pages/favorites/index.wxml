<view class="page"><custom-navbar eyebrow="个人中心" title="我的收藏"/><view class="page-content"><view class="segmented"><text class="{{active === item.id ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="id" data-id="{{item.id}}" bindtap="tab">{{item.text}}</text></view><view wx:if="{{items.length}}" class="favorite-list"><view class="favorite-card" wx:for="{{items}}" wx:key="id"><image wx:if="{{item.image}}" src="{{item.image}}" lazy-load/><view data-id="{{item.id}}" bindtap="open"><text>{{item.title}}</text><text>{{item.subtitle}}</text></view><button data-id="{{item.id}}" bindtap="remove">取消收藏</button></view></view><empty-state wx:else title="暂无收藏" description="遇到合适的陪诊员、医院或服务时可以收藏" button-text="去首页看看" bindaction="toHome"/></view></view>
