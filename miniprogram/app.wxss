@import "/styles/tokens.wxss";

page {
  min-height: 100%;
  background: var(--color-page);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: var(--font-body);
  box-sizing: border-box;
}

view,
text,
image,
button,
scroll-view {
  box-sizing: border-box;
}

button {
  min-width: 0;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  line-height: 1.2;
  text-align: center;
  background: transparent;
}

button::after {
  border: 0;
}

.safe-page {
  min-height: 100vh;
  padding-bottom: calc(var(--tab-bar-height) + env(safe-area-inset-bottom) + 32rpx);
}
