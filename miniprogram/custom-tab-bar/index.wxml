<view wx:if="{{!hidden}}" class="tab-shell">
  <view class="tab-divider"></view>
  <button
    wx:for="{{tabs}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'is-selected' : ''}}"
    data-index="{{index}}"
    bindtap="onSwitch"
    aria-label="{{item.text}}"
  >
    <view class="tab-icon">
      <app-icon
        name="{{item.icon}}"
        variant="{{selected === index ? 'tab-selected' : 'tab-unselected'}}"
        size="40"
        label="{{item.text}}"
      />
    </view>
    <text class="tab-text">{{item.text}}</text>
  </button>
</view>
