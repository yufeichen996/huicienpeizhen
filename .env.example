NODE_ENV=development
APP_ENV=development
HOST=127.0.0.1
PORT=8797
DATABASE_FILE=server/.data/development.sqlite
LOG_DIR=server/.logs
UPLOAD_DIR=server/.uploads
TOKEN_TTL_SECONDS=7200
MAX_BODY_BYTES=1048576
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8797
TRUST_PROXY=false
SEED_TEST_DATA=true
ALLOW_DEMO_AUTH=false

WECHAT_LOGIN_ENABLED=false
WECHAT_PAYMENT_ENABLED=false
MINIPROGRAM_ENABLED=false
SUBSCRIBE_MESSAGE_ENABLED=false

BOOTSTRAP_INSTITUTION_PASSWORD=replace-with-local-test-password
BOOTSTRAP_ADMIN_PASSWORD=replace-with-local-test-password
DATA_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
ORG_API_BASE_URL=http://127.0.0.1:8797
ADMIN_API_BASE_URL=http://127.0.0.1:8797
